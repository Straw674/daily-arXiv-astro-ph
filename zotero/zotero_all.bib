  shorttitle = {Cosmic Chronometers with Galaxy Clusters},
  author = {Tomasetti, E. and Moresco, M. and Granata, G. and D'Addona, M. and Bergamini, P. and Grillo, C. and Mercurio, A. and Rosati, P. and Cimatti, A. and Tortorelli, L. and Schuldt, S. and Meneghetti, M.},
