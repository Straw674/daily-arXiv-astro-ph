  title = {Cosmological Parameter Analysis Including {{SDSS Ly-alpha}} Forest and Galaxy Bias: Constraints on the Primordial Spectrum of Fluctuations, Neutrino Mass, and Dark Energy},
  shorttitle = {Cosmological Parameter Analysis Including {{SDSS Ly-alpha}} Forest and Galaxy Bias},
  author = {Seljak, U. and Makarov, A. and McDonald, P. and Anderson, S. and Bahcall, N. and Brinkmann, J. and Burles, S. and Cen, R. and Doi, M. and Gunn, J. and Ivezic, Z. and Kent, S. and Lupton, R. and Munn, J. and Nichol, R. and Ostriker, J. and Schlegel, D. and Tegmark, M. and den Berk, D. Van and Weinberg, D. and York, D.},
  year = 2005,
  month = may,
  journal = {Physical Review D},
  volume = {71},
  number = {10},
  eprint = {astro-ph/0407372},
  pages = {103515},
  issn = {1550-7998, 1550-2368},
  doi = {10.1103/PhysRevD.71.103515},
  urldate = {2024-12-24},
  abstract = {We combine the constraints from the recent Ly-alpha forest and bias analysis of the SDSS with previous constraints from SDSS galaxy clustering, the latest supernovae, and WMAP . Combining WMAP and the lya we find for the primordial slope n\_s=0.98\textbackslash pm 0.02. We see no evidence of running, dn/d\textbackslash ln k=-0.003\textbackslash pm 0.010, a factor of 3 improvement over previous constraints. We also find no evidence of tensors, r{$<$}0.36 (95\% c.l.). A positive correlation between tensors and primordial slope disfavors chaotic inflation type models with steep slopes: V \textbackslash propto \textbackslash phi\textasciicircum 4 is outside the 3-sigma contour. For the amplitude we find sigma\_8=0.90\textbackslash pm 0.03 from the lyaf and WMAP alone. We find no evidence of neutrino mass: for the case of 3 massive neutrino families with an inflationary prior, \textbackslash sum m\_\textbraceleft\textbackslash nu\textbraceright{$<$}0.42eV and the mass of lightest neutrino is m\_1{$<$}0.13eV at 95\% c.l. For the 3 massless + 1 massive neutrino case we find m\_\textbraceleft\textbackslash nu\textbraceright{$<$}0.79eV for the massive neutrino, excluding at 95\% c.l. all neutrino mass solutions compatible with the LSND results. We explore dark energy constraints in models with a fairly general time dependence of dark energy equation of state, finding Omega\_lambda=0.72\textbackslash pm 0.02, w(z=0.3)=-0.98\textasciicircum\textbraceleft +0.10\textbraceright\_\textbraceleft -0.12\textbraceright, the latter changing to w(z=0.3)=-0.92\textasciicircum\textbraceleft +0.09\textbraceright\_\textbraceleft -0.10\textbraceright{} if tensors are allowed. We find no evidence for variation of the equation of state with redshift, w(z=1)=-1.03\textasciicircum\textbraceleft +0.21\textbraceright\_\textbraceleft -0.28\textbraceright. These results rely on the current understanding of the lyaf and other probes, which need to be explored further both observationally and theoretically, but extensive tests reveal no evidence of inconsistency among different data sets used here.},
  archiveprefix = {arXiv},
  langid = {american},
  keywords = {/finished},
  annotation = {Read\_Status: New\\
Read\_Status\_Date: 2024-12-24T15:24:28.161Z},
  file = {/Users/xinq/Zotero/storage/A7SR4MK5/Seljak 等 - 2005 - Cosmological parameter analysis including SDSS Ly-alpha forest and galaxy bias constraints on the p.pdf}
}

@article{Seljak2006CanSterileNeutrinos,
  title = {Can {{Sterile Neutrinos Be}} the {{Dark Matter}}?},
  author = {Seljak, Uro{\v s} and Makarov, Alexey and McDonald, Patrick and Trac, Hy},
  year = 2006,
  month = nov,
  journal = {Physical Review Letters},
  volume = {97},
  pages = {191303},
  publisher = {APS},
  issn = {0031-9007},
  doi = {10.1103/PhysRevLett.97.191303},
  urldate = {2024-12-20},
  abstract = {We use the Ly-{$\alpha$} forest power spectrum measured by the Sloan Digital Sky Survey and high-resolution spectroscopy observations in combination with cosmic microwave background and galaxy clustering constraints to place limits on a sterile neutrino as a dark matter candidate in the warm dark matter scenario. Such a neutrino would be created in the early Universe through mixing with an active neutrino and would suppress structure on scales smaller than its free-streaming scale. We ran a series of high-resolution hydrodynamic simulations with varying neutrino masses to describe the effect of a sterile neutrino on the Ly-{$\alpha$} forest power spectrum. We find that the mass limit is ms{$>$}13keV at 95\% C.L. (9 keV at 99.9\%), which is above the upper limit allowed by x-ray constraints, excluding this candidate from being all of the dark matter in this model.},
