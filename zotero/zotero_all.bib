}

@article{Dong2022UniversalSpecificMerger,
  title = {The {{Universal Specific Merger Rate}} of {{Dark Matter Halos}}},
  author = {Dong, Fuyu and Zhao, Donghai and Han, Jiaxin and Li, Zhaozhou and Jing, Yipeng and Yang, Xiaohu},
