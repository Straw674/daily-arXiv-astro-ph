  author = {de Haan, Tijmen and Ting, Yuan-Sen and Ghosal, Tirthankar and Nguyen, Tuan Dung and Accomazzi, Alberto and Wells, Azton and Ramachandra, Nesar and Pan, Rui and Sun, Zechang},
