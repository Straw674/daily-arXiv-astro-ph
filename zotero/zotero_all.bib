@article{Khanday2022MorphologyColourmagnitudeScaling,
  title = {Morphology, Colour-Magnitude, and Scaling Relations of Galaxies in {{Abell}} 426},
  author = {Khanday, Sheeraz A. and Saha, Kanak and Iqbal, Nasser and Dhiwar, Suraj and Pahwa, Isha},
  year = 2022,
