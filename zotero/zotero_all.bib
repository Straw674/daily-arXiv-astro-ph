@article{Yan2025KiDSLegacyAngularGalaxy,
  title = {{{KiDS-Legacy}}: {{Angular}} Galaxy Clustering from Deep Surveys with Complex Selection Effects},
  shorttitle = {{{KiDS-Legacy}}},
  author = {Yan, Ziang and Wright, Angus H. and Chisari, Nora Elisa and Georgiou, Christos and Joudaki, Shahab and Loureiro, Arthur and Reischke, Robert and Asgari, Marika and Bilicki, Maciej and Dvornik, Andrej and Heymans, Catherine and Hildebrandt, Hendrik and Jalan, Priyanka and Joachimi, Benjamin and Lesci, Giorgio Francesco and Li, Shun-Sheng and Linke, Laila and Mahony, Constance and Moscardini, Lauro and Napolitano, Nicola R. and St{\"o}lzner, Benjamin and {Wietersheim-Kramsta}, Maximilian Von and Yoon, Mijin},
  year = 2025,
  month = feb,
  journal = {Astronomy \& Astrophysics},
  volume = {694},
  pages = {A259},
  publisher = {EDP Sciences},
  issn = {0004-6361, 1432-0746},
  doi = {10.1051/0004-6361/202452808},
  urldate = {2025-09-26},
  abstract = {Photometric galaxy surveys, despite their limited resolution along the line of sight, encode rich information about the large-scale structure (LSS) of the Universe thanks to the high number density and extensive depth of the data. However, the complicated selection effects in wide and deep surveys can potentially cause significant bias in the angular two-point correlation function (2PCF) measured from those surveys. In this paper, we measure the 2PCF from the newly published KiDS-Legacy sample. Given an \emph{r{$<$}i/{$>$}-band 5\emph{{$\sigma<$}i/{$>$} magnitude limit of 24.8 and survey footprint of 1347 deg\textsuperscript{2{$<$}sup/{$>$}, it achieves an excellent combination of sky coverage and depth for such a measurement. We find that complex selection effects, primarily induced by varying seeing, introduce over-estimation of the 2PCF by approximately an order of magnitude. To correct for such effects, we apply a machine learning-based method to recover an organised random (OR) that presents the same selection pattern as the galaxy sample. The basic idea is to find the selection-induced clustering of galaxies using a combination of self-organising maps (SOMs) and hierarchical clustering (HC). This unsupervised machine learning method is able to recover complicated selection effects without specifying their functional forms. We validate this SOM+HC method on mock deep galaxy samples with realistic systematics and selections derived from the KiDS-Legacy catalogue. Using mock data, we demonstrate that the OR delivers unbiased 2PCF cosmological parameter constraints, removing the 27\emph{{$\sigma<$}i/{$>$} offset in the galaxy bias parameter that is recovered when adopting uniform randoms. Blinded measurements on the real KiDS-Legacy data show that the corrected 2PCF is robust to the SOM+HC configuration near the optimal set-up suggested by the mock tests.}}}}},
  copyright = {\copyright{} The Authors 2025},
  langid = {english},
  file = {/Users/xinq/Zotero/storage/ZXTLW9NT/Yan 等 - 2025 - KiDS-Legacy Angular galaxy clustering from deep surveys with complex selection effects.pdf}
}

@article{Yang2012EvolutionGalaxyDarkMatter,
  title = {Evolution of the {{Galaxy-Dark Matter Connection}} and the {{Assembly}} of {{Galaxies}} in {{Dark Matter Halos}}},
  author = {Yang, Xiaohu and Mo, H. J. and {van den Bosch}, Frank C. and Zhang, Youcai and Han, Jiaxin},
  year = 2012,
  month = jun,
  journal = {The Astrophysical Journal},
  volume = {752},
  pages = {41},
  issn = {0004-637X},
  doi = {10.1088/0004-637X/752/1/41},
  urldate = {2025-09-08},
  abstract = {We present a new model to describe the galaxy-dark matter connection across cosmic time, which unlike the popular subhalo abundance-matching technique is self-consistent in that it takes account of the facts that (1) subhalos are accreted at different times and (2) the properties of satellite galaxies may evolve after accretion. Using observations of galaxy stellar mass functions (SMFs) out to z \textasciitilde{} 4, the conditional SMF at z \textasciitilde{} 0.1 obtained from Sloan Digital Sky Survey galaxy group catalogs, and the two-point correlation function (2PCF) of galaxies at z \textasciitilde{} 0.1 as a function of stellar mass, we constrain the relation between galaxies and dark matter halos over the entire cosmic history from z \textasciitilde{} 4 to the present. This relation is then used to predict the median assembly histories of different stellar mass components within dark matter halos (central galaxies, satellite galaxies, and halo stars). We also make predictions for the 2PCFs of high-z galaxies as function of stellar mass. Our main findings are the following: (1) Our model reasonably fits all data within the observational uncertainties, indicating that the {$\Lambda$}CDM concordance cosmology is consistent with a wide variety of data regarding the galaxy population across cosmic time. (2) At low-z, the stellar mass of central galaxies increases with halo mass as M 0.3 and M gsim 4.0 at the massive and low-mass ends, respectively. The ratio M *, c /M reveals a maximum of \textasciitilde 0.03 at a halo mass M \textasciitilde{} 1011.8 h -1 M {$\odot$}, much lower than the universal baryon fraction (\textasciitilde 0.17). At higher redshifts the maximum in M *, c /M remains close to \textasciitilde 0.03, but shifts to higher halo mass. (3) The inferred timescale for the disruption of satellite galaxies is about the same as the dynamical friction timescale of their subhalos. (4) The stellar mass assembly history of central galaxies is completely decoupled from the assembly history of its host halo; the ratio M *, c /M initially increases rapidly with time until the halo mass reaches \textasciitilde 1012 h -1 M {$\odot$}, at which point M *, c /M \textasciitilde{} 0.03. Once M {$>$}\textasciitilde{} 1012 h -1 M {$\odot$}, there is little growth in M *, c , causing the ratio M *, c /M to decline. In Milky Way (MW)-sized halos more than half of the central stellar mass is assembled at z {$<$}\textasciitilde{} 0.5. (5) In low-mass halos, the accretion of satellite galaxies contributes little to the formation of their central galaxies, indicating that most of their stars must have formed in situ. In massive halos more than half of the stellar mass of the central galaxy has to be formed in situ, and the accretion of satellites can only become significant at z {$<$}\textasciitilde{} 2. (6) The total mass in halo stars is more than twice that of the central galaxy in massive halos, but less than 10\% of M *, c in MW-sized halos. (7) The 2PCFs of galaxies on small scales hold important information regarding the evolution of satellite galaxies, which at high-z is predicted to be much steeper than at low-z, especially for more massive galaxies. We discuss various implications of our findings regarding the formation and evolution of galaxies in a {$\Lambda$}CDM cosmology.},
  annotation = {ADS Bibcode: 2012ApJ...752...41Y},
  file = {/Users/xinq/Zotero/storage/HDQLU7ZP/Yang 等 - 2012 - Evolution of the Galaxy-Dark Matter Connection and the Assembly of Galaxies in Dark Matter Halos.pdf}
}

