@article{Prole2019ObservationalPropertiesUltradiffuse,
  title = {Observational Properties of Ultra-Diffuse Galaxies in Low-Density Environments: Field {{UDGs}} Are Predominantly Blue and Star Forming},
  shorttitle = {Observational Properties of Ultra-Diffuse Galaxies in Low-Density Environments},
  author = {Prole, D J and {van~der~Burg}, R F J and Hilker, M and Davies, J I},
