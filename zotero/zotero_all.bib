@article{Rozo2015RedMaPPerIVPhotometric,
  title = {{{redMaPPer}} - {{IV}}. {{Photometric}} Membership Identification of Red Cluster Galaxies with 1 per Cent Precision},
  author = {Rozo, E. and Rykoff, E. S. and Becker, M. and Reddick, R. M. and Wechsler, R. H.},
