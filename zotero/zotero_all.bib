@misc{Casey2014DustyStarFormingGalaxies,
  title = {Dusty {{Star-Forming Galaxies}} at {{High Redshift}}},
  author = {Casey, Caitlin M. and Narayanan, Desika and Cooray, Asantha},
  year = 2014,
  month = feb,
  number = {arXiv:1402.1456},
  eprint = {1402.1456},
