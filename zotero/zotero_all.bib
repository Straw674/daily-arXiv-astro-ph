  urldate = {2025-09-03},
  abstract = {Recent observations suggest that the extended stellar halos of low-redshift massive galaxies are tightly connected to the assembly of their dark matter halos. In this paper, we use the Illustris, IllustrisTNG100, and IllustrisTNG300 simulations to compare how different stellar aperture masses trace halo mass. For massive central galaxies (\$M\_\textbackslash star\textbackslash geq 10\textasciicircum\textbraceleft 11.2\textbraceright M\_\textbackslash odot\$), we find that a 2D outskirt stellar mass measured between 50 to 100 kpc (\$M\_\textbraceleft\textbackslash star,[50,100]\textbraceright\$) consistently outperforms other aperture-based stellar masses. We further show that \$M\_\textbraceleft\textbackslash star,[50,100]\textbraceright\$ correlates better with halo mass than the total amount of accreted stars (the ex situ mass), which suggests that not all accreted stars connect to halo assembly equally. While the galaxy formation recipes are different between Illustris and IllustrisTNG100, the two simulations yield consistent ex situ outskirt fractions for massive galaxies (about 70\% in \$M\_\textbraceleft\textbackslash star,[50,100]\textbraceright\$). These results demonstrate the potential of using the outskirt stellar mass to deepen our understanding of galaxy-halo connection in massive dark matter halos and trace dark matter halos better.},
  archiveprefix = {arXiv},
  langid = {american},
  keywords = {/finished},
