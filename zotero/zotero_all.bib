@misc{Durodola2024ExploringAGNFraction,
  title = {Exploring the {{AGN Fraction}} of a {{Sample}} of {{JWST}}'s {{Little Red Dots}} at \$5 {$<$} z {$<$} 8\$: {{Overmassive Black Holes Are Strongly Favored}}},
  shorttitle = {Exploring the {{AGN Fraction}} of a {{Sample}} of {{JWST}}'s {{Little Red Dots}} at \$5 {$<$} z {$<$} 8\$},
  author = {Durodola, Emmanuel and Pacucci, Fabio and Hickox, Ryan C.},
  year = 2024,
  month = jun,
