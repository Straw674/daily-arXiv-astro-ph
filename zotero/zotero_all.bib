}

@article{Haigh2021OptimisingComparingSourceextraction,
  title = {Optimising and Comparing Source-Extraction Tools Using Objective Segmentation Quality Criteria},
  author = {Haigh, Caroline and Chamba, Nushkia and Venhola, Aku and Peletier, Reynier and Doorenbos, Lars and Watkins, Matthew and Wilkinson, Michael H. F.},
  year = 2021,
