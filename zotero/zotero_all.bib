Read\_Status\_Date: 2024-08-26T07:14:16.052Z},
  file = {/Users/xinq/Zotero/storage/78SILG3R/Román et al_2021_Discovery and analysis of low-surface-brightness galaxies in the environment of.pdf}
}

@article{Romano2024AnswersFrequentlyAsked,
  title = {Answers to Frequently Asked Questions about the Pulsar Timing Array {{Hellings}} and {{Downs}} Curve},
  author = {Romano, Joseph D. and Allen, Bruce},
  year = 2024,
  month = sep,
  journal = {Classical and Quantum Gravity},
  volume = {41},
  number = {17},
  eprint = {2308.05847},
  primaryclass = {gr-qc},
  pages = {175008},
  issn = {0264-9381, 1361-6382},
  doi = {10.1088/1361-6382/ad4c4c},
  urldate = {2025-06-02},
  abstract = {We answer frequently asked questions (FAQs) about the Hellings and Downs correlation curve -- the "smoking-gun" signature that pulsar timing arrays (PTAs) have detected gravitational waves (GWs). Many of these questions arise from inadvertently applying intuition about the effects of GWs on LIGO-like detectors to the case of pulsar timing, where not all of it applies. This is because Earth-based detectors, like LIGO and Virgo, have arms that are short (km scale) compared to the wavelengths of the GWs that they detect (approx 100-10,000 km). In contrast, PTAs respond to GWs whose wavelengths (tens of light-years) are much shorter than their arms (a typical PTA pulsar is hundreds to thousands of light-years from Earth). To demonstrate this, we calculate the time delay induced by a passing GW along an Earth-pulsar baseline (a "one-arm, one-way" detector) and compare it in the "short-arm" (LIGO-like) and "long-arm" (PTA) limits. This provides qualitative and quantitative answers to many questions about the Hellings and Downs curve. The resulting FAQ sheet should help in understanding the "evidence for GWs" recently announced by several PTA collaborations.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/LDRHNRG6/Romano和Allen - 2024 - Answers to frequently asked questions about the pulsar timing array Hellings and Downs curve.pdf}
}

@article{Rong2017UniverseUltradiffuseGalaxies,
  title = {A {{Universe}} of Ultradiffuse Galaxies: Theoretical Predictions from {{$\Lambda$CDM}} Simulations},
  shorttitle = {A {{Universe}} of Ultradiffuse Galaxies},
  author = {Rong, Yu and Guo, Qi and Gao, Liang and Liao, Shihong and Xie, Lizhi and Puzia, Thomas H. and Sun, Shuangpeng and Pan, Jun},
  year = 2017,
