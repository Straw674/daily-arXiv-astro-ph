@article{Koda2015APPROXIMATELYTHOUSANDULTRADIFFUSE,
  title = {{{APPROXIMATELY A THOUSAND ULTRA-DIFFUSE GALAXIES IN THE COMA CLUSTER}}},
  author = {Koda, Jin and Yagi, Masafumi and Yamanoi, Hitomi and Komiyama, Yutaka},
  year = 2015,
