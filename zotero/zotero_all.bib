}

@misc{Sabogal2025UpdatedCosmologicalConstraints,
  title = {Updated {{Cosmological Constraints}} from {{2D BAO Measurements}}: {{A New Compilation}} and {{Comparison}} with {{DESI DR2}}},
  shorttitle = {Updated {{Cosmological Constraints}} from {{2D BAO Measurements}}},
  author = {Sabogal, Miguel A. and Nunes, Rafael C. and Avila, Felipe and Bernui, Armando},
  year = 2025,
  month = oct,
  number = {arXiv:2510.16141},
  eprint = {2510.16141},
  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2510.16141},
  urldate = {2025-10-30},
  abstract = {We investigate and update observational constraints on cosmological parameters within the \$\textbackslash Lambda\$CDM and dynamical dark energy frameworks, using a new compilation of the transverse (or 2D) BAO data, measurements that provide a relatively model-independent estimate of the BAO angular scale at a given redshift. Firstly, we assess the consistency of this compilation with CMB-Planck data and recent BAO results from the DESI collaboration. After confirming minimal tension with CMB data, we perform a series of joint analyses combining CMB data with the 2D\textasciitilde BAO compilation, as well as with several recent Type Ia supernova (SNIa) samples. In all cases, we compare the constraining power of the 2D\textasciitilde BAO data with that of DESI\textasciitilde DR2 samples. Our results indicate that combining 2D\textasciitilde BAO with CMB and SNIa data provides observational constraints that are competitive with those obtained using DESI\textasciitilde DR2. Although the precision of DESI\textasciitilde DR2 results remains higher, as expected due to the more accurate 3D measurements, the 2D\textasciitilde BAO compilation yields strong constraints. For example, in the \$\textbackslash Lambda\$CDM context, we find \$H\_0 = 68.16\textasciicircum\textbraceleft +0.41\textbraceright\_\textbraceleft -0.37\textbraceright{} \textbackslash,\textbackslash,\textbackslash, \textbackslash text\textbraceleft km s\textbraceright\textasciicircum\textbraceleft -1\textbraceright\textbackslash,\textbackslash text\textbraceleft Mpc\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$ (CMB + 2D\textasciitilde BAO) and \$\textbackslash Sigma m\_\textbraceleft\textbackslash nu\textbraceright{} {$<$} 0.081\textasciitilde\textbackslash mathrm\textbraceleft eV\textbraceright\$ (95\textbackslash\%\textasciitilde CL). These results are comparable to analogous analyses using DESI\textasciitilde DR2. Several other cases are analyzed and presented in the main text. Due to these results, we conclude that this new 2D\textasciitilde BAO compilation is both robust and competitive in constraining cosmological parameters, and, importantly, it does not exhibit significant tension with CMB measurements.},
  archiveprefix = {arXiv},
  langid = {american},
  file = {/Users/xinq/Zotero/storage/WA6QSN4T/Sabogal 等 - 2025 - Updated Cosmological Constraints from 2D BAO Measurements A New Compilation and Comparison with DES.pdf}
}

@article{Sahni2005DarkMatterDark,
  title = {Dark {{Matter}} and {{Dark Energy}}},
  author = {Sahni, Varun},
  year = 2005,
  month = jan,
  journal = {The Physics of the Early Universe},
  volume = {653},
  pages = {141},
  doi = {10.1007/978-3-540-31535-3_5},
  urldate = {2024-05-15},
  abstract = {I briefly review our current understanding of dark matter and dark energy. The first part of this review focusses on issues pertaining to dark matter including observational evidence for its existence, current constraints and the abundance of substructure and cuspy core issues which arise in CDM. I also briefly describe MOND. The second part of this review focusses on dark energy. In this part I discuss the significance of the cosmological constant problem which leads to a predicted value of the cosmological constant which is almost 10123 times larger than the observed value /8 G 10-47GeV4. Setting {$\lambda$} to this small value ensures that the acceleration of the universe is a fairly recent phenomenon giving rise to the cosmic coincidence" conundrum according to which we live during a special epoch when the density in matter and {$\lambda$} are almost equal. Anthropic arguments are briefly discussed but more emphasis is placed upon dynamical dark energy models in which the equation of state is time dependent. These include Quintessence, Braneworld models, Chaplygin gas and Phantom energy. Model independent methods to determine the cosmic equation of state and the Statefinder diagnostic are also discussed. The Statefinder has the attractive property for LCDM, which is helpful for differentiating between LCDM and rival dark energy models. The review ends with a brief discussion of the fate of the universe in dark energy models.},
  annotation = {ADS Bibcode: 2005LNP...653..141S\\
Read\_Status: New\\
Read\_Status\_Date: 2024-08-26T07:14:16.054Z},
  file = {/Users/xinq/Zotero/storage/9IL73JXT/Sahni_2005_Dark Matter and Dark Energy.pdf}
}

@article{Saifollahi2022ImplicationsGalaxyFormation,
  title = {Implications for Galaxy Formation Models from Observations of Globular Clusters around Ultra-Diffuse Galaxies},
  author = {Saifollahi, Teymoor and Zaritsky, Dennis and Trujillo, Ignacio and Peletier, Reynier F. and Knapen, Johan H. and Amorisco, Nicola and Beasley, Michael A. and Donnerstein, Richard},
  year = 2022,
  month = apr,
  journal = {Monthly Notices of the Royal Astronomical Society},
  volume = {511},
  pages = {4633--4659},
  issn = {0035-8711},
  doi = {10.1093/mnras/stac328},
  urldate = {2023-07-24},
  abstract = {We present an analysis of Hubble Space Telescope observations of globular clusters (GCs) in six ultradiffuse galaxies (UDGs) in the Coma cluster, a sample that represents UDGs with large effective radii (Re), and use the results to evaluate competing formation models. We eliminate two significant sources of systematic uncertainty in the determination of the number of GCs, NGC by using sufficiently deep observations that (i) reach the turnover of the globular cluster luminosity function (GCLF) and (ii) provide a sufficient number of GCs with which to measure the GC number radial distribution. We find that NGC for these galaxies is on average \textasciitilde{} 20, which implies an average total mass, Mtotal, \textasciitilde{} 1011 M{$\odot$} when applying the relation between NGC and Mtotal. This value of NGC lies at the upper end of the range observed for dwarf galaxies of the same stellar mass and is roughly a factor of two larger than the mean. The GCLF, radial profile, and average colour are more consistent with those observed for dwarf galaxies than with those observed for the more massive (L*) galaxies, while both the radial and azimuthal GC distributions closely follow those of the stars in the host galaxy. Finally, we discuss why our observations, specifically the GC number and GC distribution around these six UDGs, pose challenges for several of the currently favoured UDG formation models.},
  annotation = {ADS Bibcode: 2022MNRAS.511.4633S\\
Read\_Status: New\\
Read\_Status\_Date: 2024-08-26T07:14:16.073Z},
  file = {/Users/xinq/Zotero/storage/K75BLK33/Saifollahi et al_2022_Implications for galaxy formation models from observations of globular clusters.pdf}
}

@misc{Saintonge2025InterstellarMediuma,
  title = {The {{Interstellar Medium}}},
  author = {Saintonge, Amelie},
  year = 2025,
  month = apr,
  number = {arXiv:2504.01410},
  eprint = {2504.01410},
  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2504.01410},
  urldate = {2026-03-22},
  abstract = {The interstellar medium (ISM) is the material that fills the space between the stars in all galaxies; it is a multi-phase medium in pressure equilibrium, with densities and temperatures covering over 6 orders of magnitude. Although accounting for only a small fraction of the mass of any given galaxy, it is a vital component, since it holds the material responsible for galaxy growth through star formation. Studying the ISM requires careful observations at all wavelengths of the electromagnetic spectrum. This article describes the multi-phase nature of the ISM, and then puts it in the context of galaxy evolution models, emphasising the importance of the cycling of baryons in and out of galaxies. Within this framework, the ISM plays a central role: it connects the physical processes operating on very large physical- and time-scales which control the accretion of gas onto galaxies, and the small scale processes that regulate star formation.},
  archiveprefix = {arXiv},
  langid = {american},
  keywords = {/finished},
  file = {/Users/xinq/Zotero/storage/ALH93NYI/Saintonge - 2025 - The Interstellar Medium.pdf}
}

