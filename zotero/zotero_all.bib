@misc{Zhan2025BuiltinPrecisionImproving,
  title = {Built-in Precision: {{Improving}} Cluster Cosmology through the Self-Calibration of a Galaxy Cluster Sample},
  shorttitle = {Built-in Precision},
  author = {Zhan, Junhao and Reichardt, Christian L.},
  year = 2025,
