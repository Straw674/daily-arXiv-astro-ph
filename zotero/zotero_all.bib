}

@article{Hao2009PRECISIONMEASUREMENTSCLUSTER,
  title = {{{PRECISION MEASUREMENTS OF THE CLUSTER RED SEQUENCE USING AN ERROR-CORRECTED GAUSSIAN MIXTURE MODEL}}},
  author = {Hao, Jiangang and Koester, Benjamin P. and Mckay, Timothy A. and Rykoff, Eli S. and Rozo, Eduardo and Evrard, August and Annis, James and Becker, Matthew and Busha, Michael and Gerdes, David and Johnston, David E. and Sheldon, Erin and Wechsler, Risa H.},
