@article{Baldassare2014AMUSEFIELDIINUCLEATION,
  title = {{{AMUSE-FIELD}}. {{II}}. {{NUCLEATION OF EARLY-TYPE GALAXIES IN THE FIELD VERSUS CLUSTER ENVIRONMENT}}},
  author = {Baldassare, Vivienne F. and Gallo, Elena and Miller, Brendan P. and Plotkin, Richard M. and Treu, Tommaso and Valluri, Monica and Woo, Jong-Hak},
  year = 2014,
  month = aug,
  journal = {The Astrophysical Journal},
