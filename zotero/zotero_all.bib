@article{Barwell2026DependenceTriggeringMechanisms,
  title = {The Dependence of Triggering Mechanisms on Radio {{AGN}} Sub-Types: The Role of Galaxy Mergers},
  shorttitle = {The Dependence of Triggering Mechanisms on Radio {{AGN}} Sub-Types},
  author = {Barwell, Freya and Tadhunter, Clive N. and Pierce, Jonathon C. S. and Watkins, Aaron E. and Gordon, Yjan and Holden, Luke R. and Makrygianni, Lydia and Mason, Dustin T. and Singleton, Adam J. and Houghton, Rebecca J. and McLaughlin, Summer A. J. and Almeida, Cristina Ramos and Rom{\'a}n, Javier},
  year = 2026,
