  author = {Shi, Dong Dong and Zheng, Xian Zhong and Zhao, Hai Bin and Pan, Zhi Zheng and Li, Bin and Zou, Hu and Zhou, Xu and Guo, KeXin and An, Fang Xia and Li, Yu Bin},
  year = 2017,
  month = sep,
  journal = {The Astrophysical Journal},
  volume = {846},
  pages = {26},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.3847/1538-4357/aa8327},
  urldate = {2024-09-02},
  abstract = {We present a detection of 89 candidates of ultra-diffuse galaxies (UDGs) in a 4.9 degree2 field centered on the Hickson Compact Group 95 (HCG 95) using deep g- and r-band images taken with the Chinese Near Object Survey Telescope. This field contains one rich galaxy cluster (Abell 2588 at z = 0.199) and two poor clusters (Pegasus I at z = 0.013 and Pegasus II at z = 0.040). The 89 candidates are likely associated with the two poor clusters, giving about 50-60 true UDGs with a half-light radius \textbraceleft r\textbraceright\textbraceleft\textbraceleft e\textbraceright\textbraceright{$>$} 1.5 \textbraceleft kpc\textbraceright{} and a central surface brightness {$\mu$} (g,0){$>$} 24.0 mag arcsec-2. Deep z\textbackslash prime -band images are available for 84 of the 89 galaxies from the Dark Energy Camera Legacy Survey (DECaLS), confirming that these galaxies have an extremely low central surface brightness. Moreover, our UDG candidates are spread over a wide range in g - r color, and {$\sim$}26\% are as blue as normal star-forming galaxies, which is suggestive of young UDGs that are still in formation. Interestingly, we find that one UDG linked with HCG 95 is a gas-rich galaxy with H I mass 1.1\texttimes{} \textbraceleft 10\textbraceright 9 M {$\odot$} detected by the Very Large Array, and has a stellar mass of \textbraceleft M\textbraceright\textbackslash star {$\sim$} 1.8\texttimes{} \textbraceleft 10\textbraceright 8 M {$\odot$}. This indicates that UDGs at least partially overlap with the population of nearly dark galaxies found in deep H I surveys. Our results show that the high abundance of blue UDGs in the HCG 95 field is favored by the environment of poor galaxy clusters residing in H I-rich large-scale structures.},
  annotation = {ADS Bibcode: 2017ApJ...846...26S\\
Read\_Status: New\\
Read\_Status\_Date: 2024-09-02T06:12:10.790Z},
  file = {/Users/xinq/Zotero/storage/793N8ZHP/Shi 等 - 2017 - Deep Imaging of the HCG 95 Field. I. Ultra-diffuse Galaxies.pdf}
}

