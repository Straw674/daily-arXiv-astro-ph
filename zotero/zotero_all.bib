@article{Doubrawa2023GalaxyClusterOptical,
  title = {Galaxy Cluster Optical Mass Proxies from Probabilistic Memberships},
  author = {Doubrawa, Lia and Cypriano, Eduardo S and Finoguenov, Alexis and Lopes, Paulo A A and Maturi, Matteo and Gonzalez, Anthony H and Dupke, Renato},
  year = 2023,
