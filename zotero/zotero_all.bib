}

@article{Zangeneh2025EvolvingWormholesCosmological,
  title = {Evolving {{Wormholes}} in a {{Cosmological Background}}},
  author = {Zangeneh, Mahdi Kord and Lobo, Francisco S. N.},
  year = 2025,
  month = jul,
  journal = {Universe},
  volume = {11},
