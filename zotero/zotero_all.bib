@article{Trujillo2019Distance13Mpc,
  title = {A Distance of 13 {{Mpc}} Resolves the Claimed Anomalies of the Galaxy Lacking Dark Matter},
  author = {Trujillo, Ignacio and Beasley, Michael A. and Borlaff, Alejandro and Carrasco, Eleazar R. and Di Cintio, Arianna and Filho, Mercedes and Monelli, Matteo and Montes, Mireia and Roman, Javier and {Ruiz-Lara}, Tomas and Almeida, Jorge Sanchez and {Valls-Gabaud}, David and Vazdekis, Alexandre},
