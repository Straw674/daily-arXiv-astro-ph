@misc{Benavides2021QuiescentUltradiffuseGalaxies,
  title = {Quiescent {{Ultra-diffuse}} Galaxies in the Field Originating from Backsplash Orbits},
  author = {Benavides, Jos{\'e} A. and Sales, Laura V. and Abadi, Mario G. and Pillepich, Annalisa and Nelson, Dylan and Marinacci, Federico and Cooper, Michael and Pakmor, Ruediger and Torrey, Paul and Vogelsberger, Mark and Hernquist, Lars},
  year = 2021,
  month = sep,
