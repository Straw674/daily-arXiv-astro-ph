@article{Bird2023PRIYANewSuite,
  title = {{{PRIYA}}: A New Suite of {{Lyman-$\alpha$}} Forest Simulations for Cosmology},
  shorttitle = {{{PRIYA}}},
  author = {Bird, Simeon and Fernandez, Martin and Ho, Ming-Feng and Qezlou, Mahdi and Monadi, Reza and Ni, Yueying and Chen, Nianyi and Croft, Rupert and Di Matteo, Tiziana},
