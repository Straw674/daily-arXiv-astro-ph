  doi = {10.48550/arXiv.2507.05679},
  urldate = {2025-07-09},
  abstract = {We present the analysis of the stellar populations and kinematics of the globular cluster (GC) rich ultra-diffuse galaxy, PUDG-R21, using spectroscopic observations obtained with the Keck Cosmic Web Imager (KCWI). The recessional velocity is measured to be 5536\$\textbackslash pm\$10 km s\$\textasciicircum\textbraceleft\textbackslash mathrm\textbraceleft -1\textbraceright\textbraceright\$, confirming its association with the Perseus cluster. The galaxy exhibits mild rotation of 15.6\$\textbackslash pm\$10 km s\$\textasciicircum\textbraceleft\textbackslash mathrm\textbraceleft -1\textbraceright\textbraceright\$ and a stellar velocity dispersion of 19.4\$\textbackslash pm\$3.5 km s\$\textasciicircum\textbraceleft\textbackslash mathrm\textbraceleft -1\textbraceright\textbraceright\$ within the galaxy effective radius. From this, we infer a dynamical mass of M\$\_\textbraceleft\textbackslash mathrm\textbraceleft dyn\textbraceright\textbraceright =9.3\textbackslash pm3.3\textbackslash times10\textasciicircum\textbraceleft 8\textbraceright\$ M\$\_\textbraceleft\textbackslash odot\textbraceright\$. Based on a halo mass derived from PUDG-R21 GC counts, we find our dynamical mass is consistent with a cored dark matter profile. The integrated stellar population analysis reveals a predominantly old stellar population of 10.4\$\textbackslash pm\$1.2 Gyr, with intermediate-low metallicity ([M/H]=-0.64\$\textbackslash pm\$0.12 dex) and elevated alpha abundances ([Mg/Fe]=0.38\$\textbackslash pm\$0.25 dex). The inferred star formation history suggests rapid stellar assembly, likely truncating prior to or during the galaxy's infall into the cluster at an early epoch (\$\textbackslash sim\$10 Gyr ago). The analysis of stellar population gradients (age and metallicity) indicates a flat profile out to one effective radius. Here, we consider the involvement of two star formation events, initially forming a large population of metal-poor globular clusters, and then the latter contributing to the more metal-enriched diffuse stellar body. The evidence of subsequent star formation suggests this galaxy is more like an extension of the classical dwarf population than the much discussed failed galaxy UDGs.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/CY9KGVU6/Levitskiy 等 - 2025 - A Comprehensive Look at PUDG-R21 Stellar Population and Kinematics of a Globular Cluster-Rich Ultra.pdf}
}

@misc{LHuillier2024LitmusTestsFlat,
  title = {Litmus Tests of the Flat \$\textbackslash{{Lambda}}\${{CDM}} Model and Model-Independent Measurement of \${{H}}\_0r\_\textbackslash mathrm\textbraceleft d\textbraceright\$ with {{LSST}} and {{DESI}}},
  author = {L'Huillier, Benjamin and Mitra, Ayan and Shafieloo, Arman and Keeley, Ryan E. and Koo, Hanwool},
  year = 2024,
