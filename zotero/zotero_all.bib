Read\_Status\_Date: 2024-11-22T08:02:36.426Z},
  file = {/Users/xinq/Zotero/storage/BU794TQW/Veronese et al. - 2024 - Searching for HI around MHONGOOSE Galaxies via Spectral Stacking.pdf}
