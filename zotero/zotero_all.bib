@misc{Jerkstrand2025CorecollapseSupernovae,
  title = {Core-Collapse Supernovae},
  author = {Jerkstrand, Anders and Milisavljevic, Dan and M{\"u}ller, Bernhard},
  year = 2025,
  month = mar,
  number = {arXiv:2503.01321},
  eprint = {2503.01321},
  primaryclass = {astro-ph},
