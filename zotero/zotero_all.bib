  publisher = {arXiv},
  doi = {10.48550/arXiv.2510.15650},
  urldate = {2025-10-30},
  abstract = {Studying the SDSS-DR16 quasar catalog, we detect a baryon acoustic oscillation (BAO) signal in the two-point angular correlation function with a statistical significance of \$3\textbackslash sigma\$, at an effective redshift of \$z\_\textbraceleft\textbackslash rm eff\textbraceright =1.725\$. Using a simple parameterization-comprising a polynomial plus a Gaussian function-we measure the transverse BAO scale as \$\textbackslash theta\_\textbraceleft\textbackslash rm BAO\textbraceright =1.928\textasciicircum\textbraceleft\textbackslash circ\textbraceright\textbackslash pm0.094\textasciicircum\textbraceleft\textbackslash circ\textbraceright\$. This measurement is obtained from a narrow redshift shell, \$z \textbackslash in [1.72, 1.73]\$ (i.e., \$\textbackslash Delta z=0.01\$), thin enough that projection-effect corrections are negligible, making it only weakly dependent on the assumed fiducial cosmology. The only assumption adopted is isotropy in the computation of the correlation function, further ensuring that the result depends only weakly on specific cosmological-model hypotheses. We also investigate possible systematics that could affect the detection or significance of the BAO signal and find them to be subdominant or implausible. When combined with other transverse BAO measurements from the literature, our result shows good concordance-within the \$1\textbackslash sigma\$ confidence level-with the cosmological parameter values reported by the Planck and DESI collaborations. This new measurement of the transverse BAO scale, obtained from the SDSS quasar sample with minimal cosmological-model assumptions, provides an additional independent constraint for updated statistical studies aimed at probing the nature of dark energy.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/KIWLLBUT/Avila 等 - 2025 - Transverse BAO scale measurement at $z_ rm eff = 1.725$ with the SDSS quasars catalog.pdf}
}

@article{Avsajanishvili2024ObservationalConstraintsDynamical,
  title = {Observational {{Constraints}} on {{Dynamical Dark Energy Models}}},
