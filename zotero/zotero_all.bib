Read\_Status\_Date: 2024-12-23T17:23:39.486Z},
  file = {/Users/xinq/Zotero/storage/X9BUR2TX/Stark - 2016 - Galaxies in the First Billion Years After the Big Bang.pdf}
}

@misc{Stark2025ObservationsFirstGalaxies,
