@misc{Avila2025TransverseBAOScale,
  title = {Transverse {{BAO}} Scale Measurement at \$z\_\textbraceleft\textbackslash rm Eff\textbraceright{} = 1.725\$ with the {{SDSS}} Quasars Catalog},
