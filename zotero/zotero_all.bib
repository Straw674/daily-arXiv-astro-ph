  author = {Janssens, Steven R. and Abraham, Roberto and Brodie, Jean and Forbes, Duncan A. and Romanowsky, Aaron J.},
  year = 2019,
  month = dec,
  journal = {The Astrophysical Journal},
  volume = {887},
