  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2510.14464},
  urldate = {2025-10-20},
  abstract = {We examine the potential improvements in constraints on the dark energy equation of state parameter \$w\$ and matter density \$\textbackslash Omega\_M\$ from using clustering information along with number counts for future samples of thermal Sunyaev-Zel'dovich selected galaxy clusters. We quantify the relative improvement from including the clustering power spectrum information for three cluster sample sizes from 33,000 to 140,000 clusters and for three assumed priors on the mass slope and redshift evolution of the mass-observable relation. As expected, clustering information has the largest impact when (i) there are more clusters and (ii) the mass-observable priors are weaker. For current knowledge of the cluster mass-observable relationship, we find the addition of clustering information reduces the uncertainty on the dark energy equation of state, \$\textbackslash sigma(w)\$, by factors of \$1.023\textbackslash pm 0.007\$ to \$1.0790\textbackslash pm 0.011\$, with larger improvements observed with more clusters. Clustering information is more important for the matter density, with \$\textbackslash sigma(\textbackslash Omega\_M)\$ reduced by factors of \$1.068 \textbackslash pm 007\$ to \$1.145 \textbackslash pm 0.012\$. The improvement in \$w\$ constraints from adding clustering information largely vanishes after tightening priors on the mass-observable relationship by a factor of two. For weaker priors, we find clustering information improves the determination of the cluster mass slope and redshift evolution by factors of \$1.389 \textbackslash pm 0.041\$ and \$1.340 \textbackslash pm 0.039\$ respectively. These findings highlight that, with the anticipated surge in cluster detections from next generation surveys, self-calibration through clustering information will provide an independent cross-check on the mass slope and redshift evolution of the mass-observable relationship as well as enhancing the precision achievable from cluster cosmology.},
  archiveprefix = {arXiv},
  langid = {american},
  file = {/Users/xinq/Zotero/storage/RUNWWVXW/Zhan和Reichardt - 2025 - Built-in precision Improving cluster cosmology through the self-calibration of a galaxy cluster sam.pdf}
}

