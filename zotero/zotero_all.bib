  number = {arXiv:2411.15838},
  eprint = {2411.15838},
  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2411.15838},
  urldate = {2025-02-12},
  abstract = {The mean free path of ionizing photons for neutral hydrogen (\$\textbackslash lambda\_\textbackslash mathrm\textbraceleft mfp\textbraceright\textasciicircum\textbraceleft 912\textbraceright\$) is a crucial quantity in modelling the ionization state of the intergalactic medium (IGM) and the extragalactic ultraviolet background (EUVB), and is widely used in hydrodynamical simulations of galaxies and reionization. We construct the largest quasar spectrum dataset to date -- 12,595 \$\textbackslash mathrm\textbraceleft S/N\textbraceright{$>$}3\$ spectra -- using the Y1 observation of Dark Energy Spectroscopic Instrument (DESI) to make the most precise model-independent measurement of the mean free path at \$3.2\textbackslash leq z\textbackslash leq 4.6\$. By stacking the spectra in 17 redshift bins and modelling the Lyman continuum profile, we get a redshift evolution \$\textbackslash lambda\_\textbackslash mathrm\textbraceleft mfp\textbraceright\textasciicircum\textbraceleft 912\textbraceright\textbackslash propto(1+z)\textasciicircum\textbraceleft -4.27\textbraceright\$ at \$2\textbackslash leq z\textbackslash leq 5\$, which is much shallower than previous estimates. We then explore the sources of systematic bias, including the choice of intrinsic quasar continuum, the consideration of Lyman series opacity and Lyman limit opacity evolution and the definition of \$\textbackslash lambda\_\textbackslash mathrm\textbraceleft mfp\textbraceright\textasciicircum\textbraceleft 912\textbraceright\$. Combining our results with estimates of \$\textbackslash lambda\_\textbackslash mathrm\textbraceleft mfp\textbraceright\textasciicircum\textbraceleft 912\textbraceright\$ at higher redshifts, we conclude at high confidence that the evolution in \$\textbackslash lambda\_\textbackslash mathrm\textbraceleft mfp\textbraceright\textasciicircum\textbraceleft 912\textbraceright\$ steepens at \$z \textbackslash approx 5\$. We interpret this inflection as the transition from the end of HI reionization to a fully ionized plasma which characterizes the intergalactic medium of the past \$\textbackslash sim10\$ billion years.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/X4IN4X9D/Gao 等 - 2024 - Measuring the Mean Free Path of HI Ionizing Photons at $3.2leq zleq4.6$ with DESI Y1 Quasars.pdf}
}

@article{Garate-Nunez2024HyperSuprimeCamExtended,
  title = {The {{Hyper Suprime-Cam}} Extended Point Spread Functions and Applications},
  author = {{Garate-Nu{\~n}ez}, Luc{\'i}a P. and Robotham, Aaron S. G. and Bellstedt, Sabine and Davies, Luke J. M. and {Mart{\'i}nez-Lombilla}, Cristina},
  year = 2024,
  month = jun,
  journal = {Monthly Notices of the Royal Astronomical Society},
  volume = {531},
  pages = {2517--2530},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stae1292},
  urldate = {2025-01-10},
  abstract = {We present extended point spread function (PSF) models for the Hyper Suprime-Cam Subaru Strategic Program Public Data Release 3 (HSC-SSP PDR3) in all g, r, i, Z, and Y-bands. Due to its 8.2 m primary mirror and long exposure periods, HSC combines deep images with wide-field coverage. Both properties make HSC one of the most suitable observing facilities for low-surface brightness (LSB) studies, which are particularly sensitive to the PSF. By applying a median stacking technique of point-like sources with different brightness, we show how to construct the HSC-SSP PDR3 PSF models to an extent of R \textasciitilde{} 5.6 arcmin. These models are appropriate for the HSC-PDR3 intermediate-state data which do not have applied the final aggressive background subtraction. The intermediate-state data is especially stored for users interested in large extended objects, where our new PSFs provide them with a crucial tool to characterise LSB properties at large angles. We demonstrate that our HSC PSFs behave reasonably in two scenarios. In the first one, we generate 2D models of a bright star, showing no evidence of residual structures across the five bands. In the second scenario, we recreate the PSF-scattered light on mock images with special consideration of the effect of this additional flux on LSB measurements. Despite the well-behaved nature of the HSC-PDR3 PSFs, there is a non-negligible impact on the faint light present in the mock images. This impact could lead to incorrect LSB measurements if a proper star subtraction is not applied. The PSF models are publicly available to the astronomical community at github.com/luciagarate/HSC\_PSFs (DOI: 10.5281/zenodo.11273118).},
  annotation = {ADS Bibcode: 2024MNRAS.531.2517G\\
Read\_Status: New\\
Read\_Status\_Date: 2025-01-10T08:18:02.087Z},
  file = {/Users/xinq/Zotero/storage/KUNDC3ZW/Garate-Nuñez 等 - 2024 - The Hyper Suprime-Cam extended point spread functions and applications.pdf}
}

@misc{Gassis2025TracingStructureShape,
  title = {Tracing {{Structure}}: {{Shape}} and {{Centroid Deviations}} in 39 {{Strong Lensing Clusters}} as a {{Test}} of {{Cluster Formation Predictions}}},
  shorttitle = {Tracing {{Structure}}},
  author = {Gassis, Raven and Bayliss, Matthew B. and Sharon, Keren and Mahler, Guillaume and Gladders, Michael D. and McDonald, Michael and Dahle, Hakon and Florian, Michael K. and Rigby, Jane R. and Elicker, Lauren A. and Owens, M. Riley and Adhikari, Prasanna and Khullar, Gourav},
  year = 2025,
  month = nov,
  number = {arXiv:2511.22661},
  eprint = {2511.22661},
  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2511.22661},
  urldate = {2025-12-11},
  abstract = {Strong lensing galaxy clusters provide a unique and powerful way to test simulation-derived structure predictions that follow from \${$\Lambda\$$} Cold Dark Matter (\${$\Lambda\$$}CDM) cosmology. Specifically, the relative alignments of the dark matter (DM) halo, stars, and hot intracluster gas in these clusters offer insights into how well theoretical structure predictions hold. We measure the position angles, ellipticities, and locations/centroids of the brightest cluster galaxy (BCG), the Intracluster Light (ICL), the hot Intracluster Medium (ICM), and the Core Lensing Mass (CLM) for a sample of strong lensing galaxy clusters from the Sloan Giant Arcs Survey (SGAS). We measure the shapes (position angles and ellipticities) and centroids of these distributions using ellipse-fitting methods applied to different datasets: HST WFC3 imaging for the BCG and ICL, Chandra X-ray observations for the ICM, and strong-lensing mass reconstructions for the CLM. Additionally, we incorporate ICM morphological measures to classify the dynamical state of the cluster sample. Using this multi-component approach, we constrain the shape and centroids of these distributions in this sample and evaluate the different observable components in terms of their ability to trace the gravitational potential of their respective clusters. We find that misalignments between cluster components can be explained by astrophysical processes related to cluster assembly, relaxation, and merger histories. We find that the ICL is most closely aligned with its host DM halo, as traced by the CLM distribution, in both position angle and centroid. Additionally, we find that on average the ICL and CLM are more elliptical than the ICM and BCG.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/7VLNHG5S/Gassis 等 - 2025 - Tracing Structure Shape and Centroid Deviations in 39 Strong Lensing Clusters as a Test of Cluster.pdf}
}

