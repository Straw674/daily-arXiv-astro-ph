  abstract = {We present an optimized galaxy cluster finder, 3D-Matched-Filter (3D-MF), which utilizes galaxy cluster radial profiles, luminosity functions and redshift information to detect galaxy clusters in optical surveys. This method is an improvement over other matched-filter methods, most notably through implementing redshift slicing of the data to significantly reduce line-of-sight projections and related false positives. We apply our method to the Canada-France-Hawaii Telescope Legacy Survey (CFHTLS) Deep fields, finding \textasciitilde 170 galaxy clusters deg-2 in the 0.2 {$<$}= z {$<$}= 1.0 redshift range. Future surveys such as LSST and JDEM can exploit 3D-MF's automated methodology to produce complete and reliable galaxy cluster catalogues. We determine the reliability and accuracy of the statistical approach of our method through a thorough analysis of mock data from the Millennium Simulation. We detect clusters with 100 per cent completeness for M200 {$>$}= 3.0 \texttimes{} 1014 Msolar, 88 per cent completeness for M200 {$>$}= 1.0 \texttimes{} 1014 Msolar and 72 per cent completeness well into the 1013 Msolar cluster mass range. We show a 36 per cent multiple detection rate for cluster masses {$>$}=1.5 \texttimes{} 1013 Msolar and a 16 per cent false detection rate for galaxy clusters {$>$}rsim5 \texttimes{} 1013 Msolar, reporting that for clusters with masses {$<$}\textasciitilde 5 \texttimes{} 1013 Msolar false detections may increase up to \textasciitilde 24 per cent. Utilizing these selection functions we conclude that our galaxy cluster catalogue is the most complete CFHTLS Deep cluster catalogue to date.},
  annotation = {ADS Bibcode: 2010MNRAS.406..673M},
  file = {/Users/xinq/Zotero/storage/YNI3JWYI/Milkeraitis 等 - 2010 - 3D-Matched-Filter galaxy cluster finder - I. Selection functions and CFHTLS Deep clusters.pdf}
}

@misc{Miller2021BayesianFittingMultiGaussian,
