  doi = {10.48550/arXiv.2311.14659},
  urldate = {2023-12-01},
  abstract = {We present a novel approach to extracting dwarf galaxies from photometric data to measure their average halo mass profile with weak lensing. We characterise their stellar mass and redshift distributions with a spectroscopic calibration sample. Using the \$\textbraceleft\textbackslash sim\textbraceright 5000\textbackslash mathrm\textbraceleft deg\textbraceright\textasciicircum 2\$ multi-band photometry from Dark Energy Survey and redshifts from the Satellites Around Galactic Analogs (SAGA) survey with an unsupervised machine learning method, we select a low-mass galaxy sample spanning redshifts \$z\textbraceleft{$<$}\textbraceright 0.3\$ and divide it into three mass bins. From low to high median mass, the bins contain [146 420, 330 146, 275 028] galaxies and have median stellar masses of \$\textbackslash log\_\textbraceleft 10\textbraceright (M\_*/M\_\textbraceleft\textbackslash odot\textbraceright )= [8.52\textasciicircum\textbraceleft +0.57\textbraceright\_\textbraceleft -0.76\textbraceright, 9.02\textasciicircum\textbraceleft +0.50\textbraceright\_ \textbraceleft -0.64\textbraceright, 9.49\textasciicircum\textbraceleft +0.50\textbraceright\_\textbraceleft -0.58\textbraceright ]\$. We measure the stacked excess surface mass density profiles, \$\textbackslash Delta\textbackslash Sigma(R)\$, of these galaxies using galaxy--galaxy lensing with a signal-to-noise of [14, 23, 28]. Through a simulation-based forward-modelling approach, we fit the measurements to constrain the stellar-to-halo mass relation and find the median halo mass of these samples to be \$\textbackslash log\_\textbraceleft 10\textbraceright (M\_\textbraceleft\textbackslash rm halo\textbraceright/M\_\textbraceleft\textbackslash odot\textbraceright )\$ = [\$10.67\textbackslash substack\textbraceleft +0.2\textbackslash\textbackslash -0.4\textbraceright\$, \$11.01\textbackslash substack\textbraceleft +0.14 \textbackslash\textbackslash{} -0.27\textbraceright\$,\$11.40\textbackslash substack\textbraceleft +0.08\textbackslash\textbackslash -0.15\textbraceright\$]. The CDM profiles are consistent with NFW profiles over scales \$\textbraceleft\textbackslash lesssim\textbraceright 0.15 \textbackslash rm\textbraceleft h\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$Mpc. We find that \$\textbraceleft\textbackslash sim\textbraceright 20\$ per cent of the dwarf galaxy sample are satellites. This is the first measurement of the halo profiles and masses of such a comprehensive, low-mass galaxy sample. The techniques presented here pave the way for extracting and analysing even lower-mass dwarf galaxies and for more finely splitting galaxies by their properties with future photometric and spectroscopic survey data.},
  archiveprefix = {arXiv},
  annotation = {Read\_Status: New\\
Read\_Status\_Date: 2024-08-26T07:14:16.062Z},
  file = {/Users/xinq/Zotero/storage/GKJIKLUI/Thornton et al_2023_The mass profiles of dwarf galaxies from Dark Energy Survey lensing.pdf}
}

@article{Thuruthipilly2024SheddingLightLowsurfacebrightness,
  title = {Shedding Light on Low-Surface-Brightness Galaxies in Dark Energy Surveys with Transformer Models},
  author = {Thuruthipilly, H. and {Junais} and Pollo, A. and Sureshkumar, U. and Grespan, M. and Sawant, P. and Ma{\l}ek, K. and Zadrozny, A.},
  year = 2024,
  month = feb,
  journal = {Astronomy and Astrophysics},
  volume = {682},
  pages = {A4},
  issn = {0004-6361},
  doi = {10.1051/0004-6361/202347649},
  urldate = {2024-05-28},
  abstract = {Context. Low-surface-brightness galaxies (LSBGs), which are defined as galaxies that are fainter than the night sky, play a crucial role in our understanding of galaxy evolution and in cosmological models. Upcoming large-scale surveys, such as Rubin Observatory Legacy Survey of Space and Time and Euclid, are expected to observe billions of astronomical objects. In this context, using semiautomatic methods to identify LSBGs would be a highly challenging and time-consuming process, and automated or machine learning-based methods are needed to overcome this challenge. Aims: We study the use of transformer models in separating LSBGs from artefacts in the data from the Dark Energy Survey (DES) Data Release 1. Using the transformer models, we then search for new LSBGs from the DES that the previous searches may have missed. Properties of the newly found LSBGs are investigated, along with an analysis of the properties of the total LSBG sample in DES. Methods: We created eight different transformer models and used an ensemble of these eight models to identify LSBGs. This was followed by a single-component S\'ersic model fit and a final visual inspection to filter out false positives. Results: Transformer models achieved an accuracy of \textasciitilde 94\% in separating the LSBGs from artefacts. In addition, we identified 4083 new LSBGs in DES, adding an additional \textasciitilde 17\% to the LSBGs already known in DES. This also increased the number density of LSBGs in DES to 5.5 deg-2. The new LSBG sample consists of mainly blue and compact galaxies. We performed a clustering analysis of the LSBGs in DES using an angular two-point auto-correlation function and found that LSBGs cluster more strongly than their high-surface-brightness counterparts. This effect is driven by the red LSBG. We associated 1310 LSBGs with galaxy clusters and identified 317 ultradiffuse galaxies among them. We found that these cluster LSBGs are getting bluer and larger in size towards the edge of the clusters when compared with those in the centre. Conclusions: Transformer models have the potential to be equivalent to convolutional neural networks as state-of-the-art algorithms in analysing astronomical data. The significant number of LSBGs identified from the same dataset using a different algorithm highlights the substantial impact of our methodology on our capacity to discover LSBGs. The reported number density of LSBGs is only a lower estimate and can be expected to increase with the advent of surveys with better image quality and more advanced methodologies. LSBG catalog is available at the CDS via anonymous ftp to cdsarc.u-strasbg.fr (ftp://130.79.128.5) or via http://cdsarc.u-strasbg.fr/viz-bin/cat/J/A+A/682/A4},
  annotation = {ADS Bibcode: 2024A\&A...682A...4T\\
Read\_Status: New\\
Read\_Status\_Date: 2024-08-26T07:14:16.051Z},
  file = {/Users/xinq/Zotero/storage/LFNYVCPS/Thuruthipilly et al_2024_Shedding light on low-surface-brightness galaxies in dark energy surveys with.pdf}
}

@misc{Thuruthipilly2025HSCDetectingLow,
  title = {{{DES}} to {{HSC}}: {{Detecting}} Low Surface Brightness Galaxies in the {{Abell}} 194 Cluster Using Transfer Learning},
  shorttitle = {{{DES}} to {{HSC}}},
  author = {Thuruthipilly, H. and Junais and Koda, J. and Pollo, A. and Yagi, M. and Yamanoi, H. and Komiyama, Y. and Romano, M. and Ma{\l}ek, K. and Donevski, D.},
  year = 2025,
  month = feb,
  number = {arXiv:2502.03142},
  eprint = {2502.03142},
  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2502.03142},
  urldate = {2025-02-11},
  abstract = {Low surface brightness galaxies (LSBGs) are important for understanding galaxy evolution and cosmological models. The upcoming large-scale surveys are expected to uncover a large number of LSBGs, requiring accurate automated or machine learning-based methods for their detection. We study the scope of transfer learning for the identification of LSBGs. We use transformer models divided into two categories: LSBG Detection Transformer (LSBG DETR) and LSBG Vision Transformer (LSBG ViT), trained on Dark Energy Survey (DES) data, to identify LSBGs from dedicated Hyper Suprime-Cam (HSC) observations of the Abell 194 cluster, which are two magnitudes deeper than DES. The data from DES and HSC were standardized based on pixel-level surface brightness. We used two transformer ensembles to detect LSBGs. This was followed by a single-component S\textbackslash 'ersic model fit and a final visual inspection to filter out potential false positives and improve sample purity. We present a sample of 171 low surface brightness galaxies (LSBGs) in the Abell 194 cluster using HSC data, including 87 new discoveries. Of these, 159 were identified using transformer models, and 12 additional LSBGs were found through visual inspection. The transformer model achieved a true positive rate (TPR) of 93\% in HSC data without any fine-tuning. Among the LSBGs, 28 were classified as ultra-diffuse galaxies (UDGs). The number of UDGs and the radial UDG number density suggest a linear relationship between UDG numbers and cluster mass on a log scale. UDGs share similar S\textbackslash 'ersic parameters with dwarf galaxies and occupy the extended end of the \$R\_\textbraceleft\textbackslash mathrm\textbraceleft eff\textbraceright\textbraceright -M\_g\$ plane, suggesting they might be an extended subpopulation of dwarf galaxies. We have demonstrated that transformer models trained on shallower surveys can be successfully applied to deeper surveys with appropriate data normalization.},
  archiveprefix = {arXiv},
  langid = {american},
  file = {/Users/xinq/Zotero/storage/QL4BH9AL/Thuruthipilly 等 - 2025 - DES to HSC Detecting low surface brightness galaxies in the Abell 194 cluster using transfer learni.pdf}
}

@article{Tian2025COSMICGalaxyCluster,
  title = {{{COSMIC}}: {{A Galaxy Cluster}}--{{Finding Algorithm Using Machine Learning}}},
