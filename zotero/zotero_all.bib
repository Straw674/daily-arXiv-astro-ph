  eprint = {2510.10735},
  primaryclass = {astro-ph},
  pages = {52},
  issn = {0004-637X, 1538-4357},
  doi = {10.3847/1538-4357/adff86},
  urldate = {2025-10-14},
  abstract = {We present an algorithm designed to identify galaxy (proto)clusters in wide-area photometric surveys by first selecting their dominant galaxy-i.e., the Brightest Cluster Galaxy (BCG) or protoBCG-through the local stellar mass density traced by massive galaxies. We focus on its application to the Hyper Suprime-Cam Subaru Strategic Program (HSC-SSP) Wide Survey to detect candidates up to \$\textbackslash rm z \textbackslash sim 2\$. In this work, we apply the method to mock galaxy catalogs that replicate the observational constraints of the HSC-SSP Wide Survey. We derive functions that describe the probability of a massive galaxy being the dominant galaxy in a structure as a function of its stellar mass density contrast within a given redshift interval. We show that galaxies with probabilities greater than 50\textbackslash\% yield a sample of BCGs/protoBCGs with \$\textbackslash gtrsim 65\textbackslash\%\$ purity, where most of the contamination arises from galaxies in massive groups below our cluster threshold. Using the same threshold, the resulting (proto)cluster sample achieves 80\textbackslash\% purity and 50\textbackslash\% completeness for halos with \$M\_\textbraceleft\textbackslash rm\textbraceleft halo\textbraceright\textbraceright{} \textbackslash geq 10\textasciicircum\textbraceleft 14\textbraceright{} \textbackslash{} M\_\textbraceleft\textbackslash odot\textbraceright\$, reaching nearly 100\textbackslash\% completeness for \$M\_\textbraceleft\textbackslash rm\textbraceleft halo\textbraceright\textbraceright{} \textbackslash geq 10\textasciicircum\textbraceleft 14.5\textbraceright{} \textbackslash{} M\_\textbraceleft\textbackslash odot\textbraceright\$. We also assign probabilistic membership to surrounding galaxies based on stellar mass and distance to the dominant galaxy, from which we define the cluster richness as the number of galaxies more likely to be true members than contaminants. This allows us to derive a halo mass-richness relation. In a companion paper, we apply the algorithm to the HSC-SSP data and compare our catalog with others based on different cluster-finding techniques and X-ray detections.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/VUH32GZD/Vicentin 等 - 2025 - Selecting Clusters and Protoclusters via Stellar Mass Density I. Method and tests on Mock HSC-SSP c.pdf}
}

@article{Viel2006LymanalphaForestWMAP,
  title = {The {{Lyman-alpha}} Forest and {{WMAP}} Year Three},
  author = {Viel, Matteo and Haehnelt, Martin G. and Lewis, Antony},
  year = 2006,
  month = jul,
  journal = {Monthly Notices of the Royal Astronomical Society: Letters},
  volume = {370},
