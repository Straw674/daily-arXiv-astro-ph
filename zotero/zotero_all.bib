@article{Sanchez-Janssen2019HowNucleationLuminosity,
  title = {How Nucleation and Luminosity Shape Faint Dwarf Galaxies},
  author = {{S{\'a}nchez-Janssen}, R and Puzia, T H and Ferrarese, L and C{\^o}t{\'e}, P and Eigenthaler, P and Miller, B and {Ordenes-Brice{\~n}o}, Y and Peng, E W and Ribbeck, K X and Roediger, J and Spengler, C and Taylor, M A},
