  doi = {10.1007/s41114-022-00041-y},
  urldate = {2024-10-07},
  abstract = {The Laser Interferometer Space Antenna (LISA) will be a transformative experiment for gravitational wave astronomy, and, as such, it will offer unique opportunities to address many key astrophysical questions in a completely novel way. The synergy with ground-based and space-born instruments in the electromagnetic domain, by enabling multi-messenger observations, will add further to the discovery potential of LISA. The next decade is crucial to prepare the astrophysical community for LISA's first observations. This review outlines the extensive landscape of astrophysical theory, numerical simulations, and astronomical observations that are instrumental for modeling and interpreting the upcoming LISA datastream. To this aim, the current knowledge in three main source classes for LISA is reviewed; ultra-compact stellar-mass binaries, massive black hole binaries, and extreme or interme-diate mass ratio inspirals. The relevant astrophysical processes and the established modeling techniques are summarized. Likewise, open issues and gaps in our understanding of these sources are highlighted, along with an indication of how LISA could help making progress in the different areas. New research avenues that LISA itself, or its joint exploitation with upcoming studies in the electromagnetic domain, will enable, are also illustrated. Improvements in modeling and analysis approaches, such as the combination of numerical simulations and modern data science techniques, are discussed. This review is intended to be a starting point for using LISA as a new discovery tool for understanding our Universe.},
  annotation = {ADS Bibcode: 2023LRR....26....2A\\
Read\_Status: New\\
Read\_Status\_Date: 2024-10-07T19:35:08.258Z},
  file = {/Users/xinq/Zotero/storage/7AX5ETHR/Amaro-Seoane 等 - 2023 - Astrophysics with the Laser Interferometer Space Antenna.pdf}
}

@article{Amon2022NonlinearSolutionS8,
  title = {A Non-Linear Solution to the {{S8}} Tension?},
  author = {Amon, Alexandra and Efstathiou, George},
  year = 2022,
  month = nov,
  journal = {Monthly Notices of the Royal Astronomical Society},
  volume = {516},
  pages = {5355--5366},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stac2429},
  urldate = {2025-09-25},
  abstract = {Weak galaxy lensing surveys have consistently reported a lower amplitude for the matter fluctuation spectrum, as measured by the S8 parameter, than expected in the {$\Lambda$}CDM cosmology favoured by Planck. However, the expansion history follows the predictions of the Planck {$\Lambda$}CDM cosmology to high accuracy, as do measurements of lensing of the cosmic microwave background anisotropies. Redshift space distortion measurements also appear to be consistent with Planck {$\Lambda$}CDM. In this paper, we argue that these observations can be reconciled with the Planck {$\Lambda$}CDM cosmology if the matter power spectrum is suppressed more strongly on non-linear scales than assumed in analyses of weak galaxy lensing. We demonstrate this point by fitting a one-parameter model, characterizing a suppression of the non-linear power spectrum, to the KiDS-1000 weak lensing measurements. Such a suppression could be attributed to new properties of the dark matter that affect non-linear scales, or to a response of the matter fluctuations to baryonic feedback processes that are stronger than expected from recent cosmological simulations. Our proposed explanation can be tested using measurements of the amplitude of the matter fluctuation spectrum on linear scales, in particular via high precision redshift space distortion measurements from forthcoming galaxy and quasar redshift surveys.},
  annotation = {ADS Bibcode: 2022MNRAS.516.5355A},
  file = {/Users/xinq/Zotero/storage/TK5DJ49X/Amon和Efstathiou - 2022 - A non-linear solution to the S8 tension.pdf}
}

@article{Amorisco2016UltradiffuseGalaxiesHighspin,
  title = {Ultradiffuse Galaxies: The High-Spin Tail of the Abundant Dwarf Galaxy Population},
