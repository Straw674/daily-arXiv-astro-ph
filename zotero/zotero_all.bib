  eprint = {2406.10329},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2406.10329},
  urldate = {2024-12-09},
  abstract = {JWST is revolutionizing our view of the early Universe by pushing the boundaries of detectable galaxies and black holes in redshift (upward) and mass (downward). The Little Red Dots (LRDs), detected by several surveys at \$z {$>$} 4\$, present a significant interpretational challenge, as their spectral energy distributions can mimic both AGN and stellar population templates. This study analyzes eight LRDs from the CEERS survey, utilizing NIRCam and MIRI photometry. By performing SED fitting across a vast parameter space, we explore a broad range of AGN fractions, defined as the ratio of the monochromatic luminosities (AGN, galaxy, and dust) at 0.53 \$\textbackslash mu m\$ rest-frame. We find that the SEDs of all the LRDs investigated are consistent with having significant AGN contributions, with the best-fitting AGN fractions ranging between 40\% and 85\%. Moreover, assuming these LRDs do indeed host AGN, we can place limits on their black hole masses using the inferred AGN bolometric luminosities and adopting the Eddington limit. We find that, independent of the specific AGN fraction adopted, the LRDs' black holes are significantly overmassive relative to their host galaxies -- by \$\textbackslash sim 2\$ dex, and up to \$\textbackslash sim 4\$ dex in the most extreme cases -- compared to the local \$M\_\textbraceleft\textbackslash bullet\textbraceright{} - M\_\textbraceleft\textbackslash star\textbraceright\$ relation. The presence of overmassive black holes in the high-\$z\$ Universe may provide the strongest evidence yet of heavy black hole seeding occurring during the cosmic dark ages.},
  archiveprefix = {arXiv},
  annotation = {Read\_Status: New\\
Read\_Status\_Date: 2024-12-09T10:38:11.203Z},
  file = {/Users/xinq/Zotero/storage/FSWX8QZL/Durodola et al. - 2024 - Exploring the AGN Fraction of a Sample of JWST's Little Red Dots at $5  z  8$ Overmassive Black H.pdf}
}

