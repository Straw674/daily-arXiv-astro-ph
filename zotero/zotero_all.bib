  year = 2025,
  month = mar,
  publisher = {arXiv},
  doi = {10.48550/arXiv.2503.13632},
  urldate = {2025-06-04},
  abstract = {Galaxy clusters provide a unique probe of the late-time cosmic structure and serve as a powerful independent test of the \$\textbackslash Lambda\$CDM model. This work presents the first set of cosmological constraints derived with \textasciitilde 16,000 optically selected redMaPPer clusters across nearly 5,000 \$\textbackslash rm\textbraceleft deg\textbraceright\textasciicircum 2\$ using DES Year 3 data sets. Our analysis leverages a consistent modeling framework for galaxy cluster cosmology and DES-Y3 joint analyses of galaxy clustering and weak lensing (3x2pt), ensuring direct comparability with the DES-Y3 3x2pt analysis. We obtain constraints of \$S\_8 = 0.864 \textbackslash pm 0.035\$ and \$\textbackslash Omega\_\textbraceleft\textbackslash rm\textbraceleft m\textbraceright\textbraceright{} = 0.265\textasciicircum\textbraceleft +0.019\textbraceright\_\textbraceleft -0.031\textbraceright\$ from the cluster-based data vector. We find that cluster constraints and 3x2pt constraints are consistent under the \$\textbackslash Lambda\$CDM model with a Posterior Predictive Distribution (PPD) value of \$0.53\$. The consistency between clusters and 3x2pt provides a stringent test of \$\textbackslash Lambda\$CDM across different mass and spatial scales. Jointly analyzing clusters with 3x2pt further improves cosmological constraints, yielding \$S\_8 = 0.811\textasciicircum\textbraceleft +0.022\textbraceright\_\textbraceleft -0.020\textbraceright\$ and \$\textbackslash Omega\_\textbraceleft\textbackslash rm\textbraceleft m\textbraceright\textbraceright{} = 0.294\textasciicircum\textbraceleft +0.022\textbraceright\_\textbraceleft -0.033\textbraceright\$, a \$24\textbackslash\%\$ improvement in the \$\textbackslash Omega\_\textbraceleft\textbackslash rm\textbraceleft m\textbraceright\textbraceright -S\_8\$ figure-of-merit over 3x2pt alone. Moreover, we find no significant deviation from the Planck CMB constraints with a probability to exceed (PTE) value of \$0.6\$, significantly reducing previous \$S\_8\$ tension claims. Finally, combining DES 3x2pt, DES clusters, and Planck CMB places an upper limit on the sum of neutrino masses of \$\textbackslash sum m\_\textbackslash nu {$<$} 0.26\$ eV at 95\% confidence under the \$\textbackslash Lambda\$CDM model. These results establish optically selected clusters as a key cosmological probe and pave the way for cluster-based analyses in upcoming Stage-IV surveys such as LSST, Euclid, and Roman.},
  langid = {american},
  keywords = {/finished},
  annotation = {ADS Bibcode: 2025arXiv250313632D},
  file = {/Users/xinq/Zotero/storage/PFJCSRHP/DES Collaboration 等 - 2025 - Dark Energy Survey Year 3 Results Cosmological Constraints from Cluster Abundances, Weak Lensing, a.pdf}
}

