  eprint = {2406.11966},
  primaryclass = {astro-ph},
  issn = {2565-6120},
  doi = {10.33232/001c.128019},
  urldate = {2025-08-16},
  abstract = {We present the first step toward deriving cosmological constraints through the abundances of galaxy clusters selected in a \$510\textbackslash,\textbackslash mathrm\textbraceleft deg\textbraceright\textasciicircum 2\$ weak-lensing aperture mass map, constructed with the Year-Three shear catalog from the Hyper Suprime-Cam Subaru Strategic Program. We adopt a conservative source galaxy selection to construct a sample of \$129\$ weak-lensing peaks with a signal-to-noise ratio above \$4.7\$. We use semi-analytical injection simulations to derive the selection function and the mass--observable relation of our sample. These results take into account complicated uncertainties associated with weak-lensing measurements, such as the non-uniform survey depth and the complex survey geometry, projection effects from uncorrelated large-scale structures, and the intrinsic alignment of source galaxies. We also propose a novel modeling framework to make parts of the mass--observable relation insensitive to assumed cosmological parameters. Such a framework not only offers a great computational advantage to cosmological studies, but can also benefit future astrophysical studies using shear-selected clusters. Our results are an important step toward utilizing these cluster samples that are constructed nearly independent of any baryonic assumptions in upcoming deep-and-wide lensing surveys from the Vera Rubin Observatory, Euclid, and the Nancy Grace Roman Space Telescope.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/PGG8R8ZE/Chen 等 - 2025 - Weak-Lensing Shear-Selected Galaxy Clusters from the Hyper Suprime-Cam Subaru Strategic Program I..pdf}
}

@article{Chiu2024WeakLensingShearSelectedGalaxy,
  title = {Weak-{{Lensing Shear-Selected Galaxy Clusters}} from the {{Hyper Suprime-Cam Subaru Strategic Program}}: {{II}}. {{Cosmological Constraints}} from the {{Cluster Abundance}}},
  shorttitle = {Weak-{{Lensing Shear-Selected Galaxy Clusters}} from the {{Hyper Suprime-Cam Subaru Strategic Program}}},
  author = {Chiu, I.-Non and Chen, Kai-Feng and Oguri, Masamune and Rau, Markus M. and Hamana, Takashi and Lin, Yen-Ting and Miyatake, Hironao and Miyazaki, Satoshi and More, Surhud and Sunayama, Tomomi and Sugiyama, Sunao and Takada, Masahiro},
  year = 2024,
  month = oct,
  journal = {The Open Journal of Astrophysics},
  volume = {7},
  eprint = {2406.11970},
  primaryclass = {astro-ph},
  issn = {2565-6120},
  doi = {10.33232/001c.124537},
  urldate = {2025-08-16},
  abstract = {We present cosmological constraints using the abundance of weak-lensing shear-selected galaxy clusters in the Hyper Suprime-Cam (HSC) Subaru Strategic Program. The clusters are selected on the mass maps constructed using the three-year (Y3) weak-lensing data with an area of \$\textbackslash approx500\textasciitilde\$deg\$\textasciicircum 2\$, resulting in a sample size of \$129\$ clusters with high signal-to-noise ratios \$\textbackslash nu\$ of \$\textbackslash nu\textbackslash geq4.7\$. Owing to the deep, wide-field, and uniform imaging of the HSC survey, this is by far the largest sample of shear-selected clusters, in which the selection solely depends on gravity and is free from any assumptions about the dynamical state. Informed by the optical counterparts, the shear-selected clusters span a redshift range of \$z\textbackslash lesssim0.7\$ with a median of \$z\textbackslash approx0.3\$. The lensing sources are securely selected at \$z\textbackslash gtrsim0.7\$ with a median of \$z\textbackslash approx1.3\$, leading to nearly zero cluster member contamination. We carefully account for (1) the bias in the photometric redshift of sources, (2) the bias and scatter in the weak-lensing mass using a simulation-based calibration, and (3) the measurement uncertainty that is directly estimated on the mass maps using an injection-based method developed in a companion paper (Chen et al. submitted). In a blind analysis, the fully marginalized posteriors of the cosmological parameters are obtained as \$\textbackslash Omega\_\textbraceleft\textbackslash mathrm\textbraceleft m\textbraceright\textbraceright{} = 0.50\textasciicircum\textbraceleft +0.28\textbraceright\_\textbraceleft -0.24\textbraceright\$, \$\textbackslash sigma\_8 = 0.685\textasciicircum\textbraceleft +0.161\textbraceright\_\textbraceleft -0.088\textbraceright\$, \$\textbackslash hat\textbraceleft S\textbraceright\_\textbraceleft 8\textbraceright\textbackslash equiv\textbackslash sigma\_8\textbackslash left(\textbackslash Omega\_\textbraceleft\textbackslash mathrm\textbraceleft m\textbraceright\textbraceright/0.3\textbackslash right)\textasciicircum\textbraceleft 0.25\textbraceright{} = 0.835\textasciicircum\textbraceleft +0.041\textbraceright\_\textbraceleft -0.044\textbraceright\$, and \$\textbackslash sigma\_8\textbackslash left(\textbackslash Omega\_\textbraceleft\textbackslash mathrm\textbraceleft m\textbraceright\textbraceright/0.3\textbackslash right)\textasciicircum\textbraceleft 0.5\textbraceright{} = 0.993\textasciicircum\textbraceleft +0.084\textbraceright\_\textbraceleft -0.126\textbraceright\$ in a flat \$\textbackslash Lambda\$CDM model. We compare our cosmological constraints with other studies, including those based on cluster abundances, galaxy-galaxy lensing and clustering, and Cosmic Microwave Background observed by \$Planck\$, and find good agreement at levels of \$\textbackslash lesssim2\textbackslash sigma\$. [abridged]},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/GVSPGJFE/Chiu 等 - 2024 - Weak-Lensing Shear-Selected Galaxy Clusters from the Hyper Suprime-Cam Subaru Strategic Program II..pdf}
}

