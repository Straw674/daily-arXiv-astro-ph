  author = {Kluge, M. and Comparat, J. and Liu, A. and Balzer, F. and Bulbul, E. and Chitham, J. Ider and Ghirardini, V. and Garrel, C. and Bahar, Y. E. and Artis, E. and Bender, R. and Clerc, N. and Dwelly, T. and Fabricius, M. H. and Grandis, S. and {Hern{\'a}ndez-Lang}, D. and Hill, G. J. and Joshi, J. and Lamer, G. and Merloni, A. and Nandra, K. and Pacaud, F. and Predehl, P. and {Ramos-Ceja}, M. E. and Reiprich, T. H. and Salvato, M. and Sanders, J. S. and Schrabback, T. and Seppi, R. and Zelmer, S. and Zenteno, A. and Zhang, X.},
