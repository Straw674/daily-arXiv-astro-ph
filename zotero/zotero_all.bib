@article{Brescia2021PhotometricRedshiftsMachine,
  title = {Photometric {{Redshifts With Machine Learning}}, {{Lights}} and {{Shadows}} on a {{Complex Data Science Use Case}}},
  author = {Brescia, Massimo and Cavuoti, Stefano and Razim, Oleksandra and Amaro, Valeria and Riccio, Giuseppe and Longo, Giuseppe},
