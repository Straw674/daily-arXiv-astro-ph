@misc{Williams2026RoleClusterEnvironments,
  title = {The {{Role}} of {{Cluster Environments}} in {{Quiescent Galaxy Stellar Halo Assembly}}},
  author = {Williams, Devin and Damjanov, Ivana and Sawicki, Marcin and Souchereau, Harrison and Chen, Lingjian and Desprez, Guillaume and George, Angelo and Gwyn, Stephen and Arnouts, Stephane},
  year = 2026,
  month = apr,
  number = {arXiv:2604.16792},
  eprint = {2604.16792},
  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2604.16792},
  urldate = {2026-04-21},
  abstract = {External interactions drive galaxy stellar mass growth and morphological evolution. As stellar haloes-assembled largely via hierarchical accretion-preserve signatures of these processes, their growth probes how environment regulates galaxy evolution. We investigate how cluster environments influence quiescent galaxy (QG) stellar halo assembly over 0.1 \$\textbackslash leq\$ \$z\$ \$\textbackslash leq\$ 1.0 in a sample of 2,168 cluster and 94,479 field QGs of \$\textbackslash log M\_\textbraceleft\textbackslash star\textbraceright{} \textbackslash geq 9.66\$. Extended emission is traced via rest-frame \$g\$-band surface brightness (\${$\mu\_$}g\$) profiles extracted from deep HSC-SSP \$grizy\$ imaging. We study stellar halo assembly trends by linking median \${$\mu\_$}g\$ profile evolution to the underlying mass growth in galaxy subpopulations. Over 0.1 \$\textbackslash leq\$ \$z\$ \$\textbackslash leq\$ 1.0, cluster QGs build up stellar haloes faster than field QGs, with a \$\textbackslash sim23\textbackslash\%\$ and \$\textbackslash sim40\textbackslash\%\$ larger increase in integrated stellar halo luminosity (\$L\_\textbraceleft halo\textbraceright\$) in the low-mass (\$9.66 \textbackslash leq \textbackslash log M\_\textbraceleft\textbackslash star\textbraceright{} {$<$} 10.5\$) and high-mass (\$\textbackslash log M\_\textbraceleft\textbackslash star\textbraceright{} \textbackslash geq 10.5\$) samples, respectively. High-mass cluster QGs host more luminous stellar haloes than the field (mean cluster-to-field \$L\_\textbraceleft halo\textbraceright\$ ratio of \$\textbackslash sim1.2\$), while low-mass cluster QGs host less luminous stellar haloes (mean ratio of \$\textbackslash sim0.87\$). Among cluster QGs of \$\textbackslash log M\_\textbraceleft\textbackslash star\textbraceright{} \textbackslash geq 10\$, \$L\_\textbraceleft halo\textbraceright\$ increases with host cluster mass, but decreases for cluster QGs of \$\textbackslash log M\_\textbraceleft\textbackslash star\textbraceright{} {$<$} 10\$. These results suggest higher-mass cluster QGs (\$\textbackslash log M\_\textbraceleft\textbackslash star\textbraceright{} \textbackslash geq 10\$) experience enhanced stellar halo growth over 0.1 \$\textbackslash leq\$ \$z\$ \$\textbackslash leq\$ 1.0 fueled by increased merger-driven accretion, likely from minor mergers in cluster outskirts or in pre-infall group and filament environments. Lower-mass cluster QGs (\$9.66 \textbackslash leq \textbackslash log M\_\textbraceleft\textbackslash star\textbraceright{} {$<$} 10\$) instead have suppressed stellar halo growth in clusters and likely lose outer stellar material to environmental stripping or accretion by high-mass galaxies during mergers.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/A7LCATTD/Williams 等 - 2026 - The Role of Cluster Environments in Quiescent Galaxy Stellar Halo Assembly.pdf}
}

@article{Wittmann2017PopulationFaintLow,
  title = {A Population of Faint Low Surface Brightness Galaxies in the {{Perseus}} Cluster Core},
  author = {Wittmann, Carolin and Lisker, Thorsten and Tilahun, Liyualem Ambachew and Grebel, Eva K. and Conselice, Christopher J. and Penny, Samantha and Janz, Joachim and Gallagher III, John S. and Kotulla, Ralf and McCormac, James},
