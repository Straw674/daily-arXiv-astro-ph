 and Romelli, E. and Roncarelli, M. and Saglia, R. and Sakr, Z. and Sapone, D. and Sartoris, B. and Schneider, P. and Secroun, A. and Seidel, G. and Serrano, S. and Simon, P. and Sirignano, C. and Sirri, G. and Stanco, L. and Starck, J.-L. and Steinwagner, J. and {Tallada-Cresp{\'i}}, P. and Taylor, A. N. and Tereno, I. and Tessore, N. and Toft, S. and {Toledo-Moreo}, R. and Torradeflot, F. and Tutusaus, I. and Valenziano, L. and Valiviita, J. and Vassallo, T. and Kleijn, G. Verdoes and Veropalumbo, A. and Wang, Y. and Weller, J. and Zamorani, G. and Zucca, E. and Burigana, C. and Maturi, M. and Scottez, V. and Viel, M.},
  year = 2025,
  month = oct,
  number = {arXiv:2510.27505},
  eprint = {2510.27505},
  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2510.27505},
  urldate = {2025-11-03},
  abstract = {The large catalogues of galaxy clusters expected from the Euclid survey will enable cosmological analyses of cluster number counts that require accurate cosmological model predictions. One possibility is to use parametric fits calibrated against \$N\$-body simulations, that capture the cosmological parameter dependence of the halo mass function. Several studies have shown that this can be obtained through a calibration against haloes with spherical masses defined at the virial overdensity. In contrast, if different mass definitions are used for the HMF and the scaling relation, a mapping between them is required. Here, we investigate the impact of such a mapping on the cosmological parameter constraints inferred from galaxy cluster number counts. Using synthetic data from \$N\$-body simulations, we show that the standard approach, which relies on assuming a concentration-mass relation, can introduce significant systematic bias. In particular, depending on the mass definition and the relation assumed, this can lead to biased constraints at more than 2\$\textbackslash sigma\$ level. In contrast, we find that in all the cases we have considered, the mass conversion based on the halo sparsity statistics result in a systematic bias smaller than the statistical error.},
  archiveprefix = {arXiv},
  langid = {american},
  keywords = {/toread},
  file = {/Users/xinq/Zotero/storage/CI6QBTFS/Gayoux 等 - 2025 - Euclid Systematic uncertainties from the halo mass conversion on galaxy cluster number count data a.pdf}
}

