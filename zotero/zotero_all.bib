  author = {{Munoz-Mateos}, Juan Carlos and Sheth, Kartik and Regan, Michael and Kim, Taehyun and Laine, Jarkko and {Erroz-Ferrer}, Santiago and de Paz, Armando Gil and Comeron, Sebastien and Hinz, Joannah and Laurikainen, Eija and Salo, Heikki and Athanassoula, E. and Bosma, Albert and Bouquin, Alexandre Y. K. and Schinnerer, Eva and Ho, Luis and Zaritsky, Dennis and Gadotti, Dimitri and Madore, Barry and Holwerda, Benne and {Menendez-Delmestre}, Karin and Knapen, Johan H. and Meidt, Sharon and Querejeta, Miguel and Mizusawa, Trisha and Seibert, Mark and Laine, Seppo and Courtois, Helene},
