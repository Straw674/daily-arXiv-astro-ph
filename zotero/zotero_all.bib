@article{Ntampaka2015MachineLearningApproach,
  title = {A {{Machine Learning Approach}} for {{Dynamical Mass Measurements}} of {{Galaxy Clusters}}},
  author = {Ntampaka, M. and Trac, H. and Sutherland, D. J. and Battaglia, N. and P{\'o}czos, B. and Schneider, J.},
  year = 2015,
