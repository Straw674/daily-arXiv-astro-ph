  author = {Keim, Michael and Van Dokkum, Pieter},
  year = 2024,
  month = feb,
  volume = {243},
  pages = {428.08},
  urldate = {2024-05-28},
  abstract = {Two ultra-diffuse galaxies in the NGC1052 group, DF2 and DF4, pose a challenge to the standard paradigm of galaxy formation. These two galaxies share several remarkable properties including large sizes, extremely luminous globular cluster populations, and a lack of dark matter. Recent evidence suggests that the reason for these unusual properties is that DF2 and DF4, along with \textasciitilde 10 other galaxies that are on a line between them, formed in a high speed 'bullet dwarf' collision. This extreme interaction caused the galaxies' collisionless stars and dark matter to separate out from the collisional gas, which went on to form a trail of new dark matter free galaxies including DF2 and DF4. Such an event would provide insight into the nature of dark matter, ruling out alternative gravity theories and possibly providing an avenue to constrain the cross-section for dark matter self-interactions. Here we outline additional observational evidence testing this collisional formation scenario and providing insight into the NGC 1052 system, in order to gain a greater understanding of this novel, top-down channel for galaxy formation.},
  annotation = {ADS Bibcode: 2024AAS...24342808K\\
