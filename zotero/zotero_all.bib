@article{vanDokkum2022MonochromaticGlobularClusters,
  title = {Monochromatic Globular Clusters as a Critical Test of Formation Models for the Dark Matter Deficient Galaxies {{NGC1052-DF2}} and {{NGC1052-DF4}}},
  author = {{van Dokkum}, Pieter and Shen, Zili and Romanowsky, Aaron J. and Abraham, Roberto and Conroy, Charlie and Danieli, Shany and Chowdhury, Dhruba Dutta and Keim, Michael A. and Kruijssen, J. M. Diederik and Leja, Joel and {Trujillo-Gomez}, Sebastian},
  year = 2022,
  month = nov,
  journal = {The Astrophysical Journal Letters},
  volume = {940},
  number = {1},
  eprint = {2207.07129},
  primaryclass = {astro-ph},
  pages = {L9},
  issn = {2041-8205, 2041-8213},
  doi = {10.3847/2041-8213/ac94d6},
  urldate = {2023-06-25},
  abstract = {It was recently proposed that the dark matter-deficient ultra-diffuse galaxies DF2 and DF4 in the NGC 1052 group could be the products of a ``bullet dwarf'' collision between two gas-rich progenitor galaxies. In this model DF2 and DF4 formed at the same time in the immediate aftermath of the collision, and a strong prediction is that their globular clusters should have nearly identical stellar populations. Here we test this prediction by measuring accurate V606 - I814 colors from deep HST/ACS imaging. We find that the clusters are extremely homogeneous. The mean color difference between the globular clusters in DF2 and DF4 is ∆DF2-DF4 = -0.003 \textpm{} 0.005 mag and the observed scatter for the combined sample of 18 clusters with M606 {$<$} -8.6 in both galaxies is {$\sigma$}obs = 0.015 \textpm{} 0.002 mag. After accounting for observational uncertainties and stochastic cluster-to-cluster variation in the number of red giants, the remaining scatter is {$\sigma$}intr = 0.008+-00..000056 mag. Both the color difference and the scatter are an order of magnitude smaller than in other dwarf galaxies, and we infer that the bullet scenario passes an important test that could have falsified it. No other formation models have predicted this extreme uniformity of the globular clusters in the two galaxies. We find that the galaxies themselves are slightly redder than the clusters, consistent with a previously-measured metallicity difference. Numerical simulations have shown that such differences are expected in the bullet scenario, as the galaxies continued to self-enrich after the formation of the globular clusters.},
  archiveprefix = {arXiv},
  langid = {english},
  annotation = {Read\_Status: New\\
Read\_Status\_Date: 2024-08-26T07:14:16.076Z},
  file = {/Users/xinq/Zotero/storage/SCKIYQQ2/van Dokkum 等 - 2022 - Monochromatic globular clusters as a critical test.pdf}
}

