@article{Greene2020IntermediateMassBlackHoles,
  title = {Intermediate-{{Mass Black Holes}}},
  author = {Greene, Jenny E. and Strader, Jay and Ho, Luis C.},
  year = 2020,
  month = aug,
  journal = {Annual Review of Astronomy and Astrophysics},
  volume = {58},
  number = {1},
  eprint = {1911.09678},
  primaryclass = {astro-ph},
  pages = {257--312},
  issn = {0066-4146, 1545-4282},
  doi = {10.1146/annurev-astro-032620-021835},
  urldate = {2025-11-20},
  abstract = {We describe ongoing searches for intermediate-mass black holes with M\_BH \textasciitilde{} 100-10\textasciicircum 5 M\_sun. We review a range of search mechanisms, both dynamical and those that rely on accretion signatures. We find that dynamical and accretion signatures alike point to a high fraction of 10\textasciicircum 9-10\textasciicircum 10 M\_sun galaxies hosting black holes with M\_BH{$<$}10\textasciicircum 5 M\_sun. In contrast, there are no solid detections of black holes in globular clusters. There are few observational constraints on black holes in any environment with M\_BH \textasciitilde{} 100-10\textasciicircum 4 M\_sun. Considering low-mass galaxies with dynamical black hole masses and constraining limits, we find that the M\_BH-sigma\_* relation continues unbroken to M\_BH\textasciitilde 10\textasciicircum 5 M\_sun, albeit with large scatter. We believe the scatter is at least partially driven by a broad range in black hole mass, since the occupation fraction appears to be relatively high in these galaxies. We fold the observed scaling relations with our empirical limits on occupation fraction and the galaxy mass function to put observational bounds on the black hole mass function in galaxy nuclei. We are pessimistic that local demographic observations of galaxy nuclei alone could constrain seeding mechanisms, although either high-redshift luminosity functions or robust measurements of off-nuclear black holes could begin to discriminate models.},
  archiveprefix = {arXiv},
  langid = {american},
  file = {/Users/xinq/Zotero/storage/8DFJESXC/Greene 等 - 2020 - Intermediate-Mass Black Holes.pdf}
}

