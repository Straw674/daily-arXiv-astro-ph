  doi = {10.48550/arXiv.2312.14056},
  urldate = {2023-12-22},
  abstract = {Water is a key ingredient for the emergence of life as we know it. Yet, its destruction and reformation in space remains unprobed in warm gas. Here, we detect the hydroxyl radical (OH) emission from a planet-forming disk exposed to external far-ultraviolet (FUV) radiation with the James Webb Space Telescope. The observations are confronted with the results of quantum dynamical calculations. The highly excited OH infrared rotational lines are the tell-tale signs of H2O destruction by FUV. The OH infrared ro-vibrational lines are attributed to chemical excitation via the key reaction O+H=OH+H which seeds the formation of water in the gas-phase. We infer that the equivalent of the Earth ocean's worth of water is destroyed per month and replenished. These results show that under warm and irradiated conditions water is destroyed and efficiently reformed via gas-phase reactions. This process, assisted by diffusive transport, could reduce the HDO/H2O ratio in the warm regions of planet-forming disks.},
