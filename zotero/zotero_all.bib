@article{Keim2022TidalDistortionsNGC1052DF2,
  title = {Tidal {{Distortions}} in {{NGC1052-DF2}} and {{NGC1052-DF4}}: {{Independent Evidence}} for a {{Lack}} of {{Dark Matter}}},
  shorttitle = {Tidal {{Distortions}} in {{NGC1052-DF2}} and {{NGC1052-DF4}}},
  author = {Keim, Michael A. and van Dokkum, Pieter and Danieli, Shany and Lokhorst, Deborah and Li, Jiaxuan and Shen, Zili and Abraham, Roberto and Chen, Seery and Gilhuly, Colleen and Liu, Qing and Merritt, Allison and Miller, Tim B. and Pasha, Imad and Polzin, Ava},
  year = 2022,
