@misc{Nandal2025SupermassiveStarsMatch,
  title = {Supermassive {{Stars Match}} the {{Spectral Signatures}} of {{JWST}}'s {{Little Red Dots}}},
  author = {Nandal, Devesh and Loeb, Abraham},
  year = 2025,
  month = jul,
  number = {arXiv:2507.12618},
  eprint = {2507.12618},
  primaryclass = {astro-ph},
