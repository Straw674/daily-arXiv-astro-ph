@misc{Oguri2025CatalogsOpticallyselectedClusters,
  title = {Catalogs of Optically-Selected Clusters and Photometric Luminous Red Galaxies from the {{Hyper Suprime-Cam Subaru Strategic Program}} Final Year Dataset},
  author = {Oguri, Masamune and Lin, Yen-Ting and Okabe, Nobuhiro and Ota, Naomi and Chiu, I.-Non and Fujikawa, Momoka and Jian, Hung-Yu and Kodama, Tadayuki and Lin, Lihwai and Nishizawa, Atsushi J. and Shimakawa, Rhythm and Toba, Yoshiki},
