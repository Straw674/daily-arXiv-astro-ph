@article{Genzel2010GalacticCenterMassive,
  title = {The {{Galactic Center}} Massive Black Hole and Nuclear Star Cluster},
  author = {Genzel, Reinhard and Eisenhauer, Frank and Gillessen, Stefan},
  year = 2010,
  month = oct,
  journal = {Reviews of Modern Physics},
  volume = {82},
  pages = {3121--3195},
  publisher = {APS},
