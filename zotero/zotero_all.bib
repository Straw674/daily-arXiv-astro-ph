@article{Baggen2023SizesMassProfiles,
  title = {Sizes and {{Mass Profiles}} of {{Candidate Massive Galaxies Discovered}} by {{JWST}} at 7 {$<$} z {$<$} 9: {{Evidence}} for {{Very Early Formation}} of the {{Central}} 100 Pc of {{Present-day Ellipticals}}},
  shorttitle = {Sizes and {{Mass Profiles}} of {{Candidate Massive Galaxies Discovered}} by {{JWST}} at 7 {$<$} z {$<$} 9},
  author = {Baggen, Josephine F. W. and {van Dokkum}, Pieter and Labb{\'e}, Ivo and Brammer, Gabriel and Miller, Tim B. and Bezanson, Rachel and Leja, Joel and Wang, Bingjie and Whitaker, Katherine E. and Suess, Katherine A. and Nelson, Erica J.},
