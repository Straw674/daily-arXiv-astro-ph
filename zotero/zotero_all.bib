  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2510.25706},
  urldate = {2025-10-30},
  abstract = {We present a simulation-based forward-modeling framework for cosmological inference from optical galaxy-cluster samples, and apply it to the abundance and weak-lensing signals of DES-Y1 redMaPPer clusters. The model embeds cosmology-dependent optical selection using a counts-in-cylinders approach, while also accounting for cluster miscentering and baryonic feedback in lensing. Applied to DES-Y1, and assuming a flat \$\textbackslash Lambda\$CDM cosmology, we obtain \$\textbackslash Omega\_m=0.254\textasciicircum\textbraceleft +0.026\textbraceright\_\textbraceleft -0.020\textbraceright\$ and \$\textbackslash sigma\_8=0.826\textasciicircum\textbraceleft +0.030\textbraceright\_\textbraceleft -0.034\textbraceright\$, consistent with a broad suite of low-redshift structure measurements, including recent full-shape analyses, the DES/KiDS/HSC 3\$\textbackslash times\$2 results, and most cluster-abundance studies. Our results are also consistent with \textbackslash textit\textbraceleft Planck\textbraceright, with the difference being significant at \$2.58\textbackslash sigma\$. These results establish simulation-based forward-modeling of cluster abundances as a promising new tool for precision cosmology with Stage\textasciitilde IV survey data.},
  archiveprefix = {arXiv},
  langid = {american},
  keywords = {/finished},
  file = {/Users/xinq/Zotero/storage/ZD355CE2/Salcedo 等 - 2025 - Cosmological Constraints from Dark Energy Survey Year 1 Cluster Lensing and Abundances with Simulati.pdf}
}

