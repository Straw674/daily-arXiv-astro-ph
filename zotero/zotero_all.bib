. and Smith, M. and Suchyta, E. and Swanson, M. E. C. and Tarle, G. and Thomas, D. and To, C. and Troxel, M. A. and Tucker, D. L. and Varga, T. N. and {von der Linden}, A. and Walker, A. R. and Wechsler, R. H. and Weller, J. and Wilkinson, R. D. and Wu, H. and Yanny, B. and Zhang, Y. and Zhang, Z. and Zuntz, J. and {DES Collaboration}},
  year = 2020,
  month = jul,
  journal = {Physical Review D},
  volume = {102},
