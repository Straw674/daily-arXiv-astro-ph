  urldate = {2025-04-24},
  abstract = {It is explained why ultra-diffuse galaxies (UDGs), a subset of (IC 3475)-type galaxies, do not have unexpectedly large sizes but large sizes that are in line with expectations from the curved size-luminosity relation defined by brighter early-type galaxies (ETGs). UDGs extend the faint end of the (absolute magnitude, \$\textbackslash mathfrak\textbraceleft M\textbraceright\$)-log(S\textbackslash 'ersic index, \$n\$) and \$\textbackslash mathfrak\textbraceleft M\textbraceright\$-(central surface brightness, \$\textbackslash mu\_\textbraceleft\textbackslash rm 0\textbraceright\$) relations defined by ETGs, leading to the large effective half-light radii, \$R\_\textbraceleft\textbackslash rm e\textbraceright\$, in UDGs. It is detailed how the scatter in \$\textbackslash mu\_\textbraceleft\textbackslash rm 0\textbraceright\$, at a given \$\textbackslash mathfrak\textbraceleft M\textbraceright\$, relates to variations in the galaxies' values of \$n\$ and effective surface brightness, \$\textbackslash mu\_\textbraceleft\textbackslash rm e\textbraceright\$. These variations map into changes in \$R\_\textbraceleft\textbackslash rm e\textbraceright\$ and produce the scatter about the \$\textbackslash mathfrak\textbraceleft M\textbraceright\$-\$R\_\textbraceleft\textbackslash rm e\textbraceright\$ relation at fixed \$\textbackslash mathfrak\textbraceleft M\textbraceright\$. Similarly, the scatter in \$\textbackslash mathfrak\textbraceleft M\textbraceright\$, at fixed \$\textbackslash mu\_\textbraceleft\textbackslash rm 0\textbraceright\$ and \$n\$, can be mapped into changes in \$R\_\textbraceleft\textbackslash rm e\textbraceright\$. The increased scatter about the faint end of the \$\textbackslash mathfrak\textbraceleft M\textbraceright\$-\$R\_\textbraceleft\textbackslash rm e\textbraceright\$ relation and the smaller scatter about \$\textbackslash mathfrak\textbraceleft M\textbraceright\$-(isophotal radii, \$R\_\textbraceleft\textbackslash rm iso\textbraceright\$) relations are explained. Artificial and potentially misleading size-luminosity relations for UDGs are also addressed. The suggestion that there may be two types of UDG appears ill-founded, arising from the scatter about the \$\textbackslash mathfrak\textbraceleft M\textbraceright\$-\$\textbackslash mu\_\textbraceleft\textbackslash rm 0\textbraceright\$ relation, which persists at all magnitudes. Hopefully, the understanding presented here will prove helpful for interpreting the many low surface brightness galaxies that the Large Synoptic Survey Telescope will detect.},
  archiveprefix = {arXiv},
  langid = {american},
  file = {/Users/xinq/Zotero/storage/5V9RBTNT/Graham - 2025 - $R_ rm e $. II. Understanding (IC 3475)-type galaxy, aka ultra-diffuse galaxy, structural scaling r.pdf}
}

@article{Grandis2025SelectionFunctionClusters,
  title = {Selection Function of Clusters in {{Dark Energy Survey}} Year 3 Data from Cross-Matching with {{South Pole Telescope}} Detections},
