@article{Bahamonde2018DynamicalSystemsApplied,
  title = {Dynamical Systems Applied to Cosmology: {{Dark}} Energy and Modified Gravity},
  shorttitle = {Dynamical Systems Applied to Cosmology},
  author = {Bahamonde, Sebastian and B{\"o}hmer, Christian G. and Carloni, Sante and Copeland, Edmund J. and Fang, Wei and Tamanini, Nicola},
  year = 2018,
