}

@article{Allen2023HellingsDownsCorrelation,
  title = {Hellings and {{Downs}} Correlation of an Arbitrary Set of Pulsars},
  author = {Allen, Bruce and Romano, Joseph D.},
  year = 2023,
  month = aug,
  journal = {Physical Review D},
  volume = {108},
  number = {4},
  eprint = {2208.07230},
  primaryclass = {gr-qc},
  pages = {043026},
  issn = {2470-0010, 2470-0029},
  doi = {10.1103/PhysRevD.108.043026},
  urldate = {2025-06-02},
  abstract = {Pulsar timing arrays (PTAs) detect gravitational waves (GWs) via the correlations they induce in the arrival times of pulses from different pulsars. We assume that the GWs are described by a Gaussian ensemble. The mean correlation \$h\textasciicircum 2 \textbackslash mu\_\textbraceleft\textbackslash rm u\textbraceright (\textbackslash gamma)\$ as a function of the angle \$\textbackslash gamma\$ between the directions to two pulsars was predicted by Hellings and Downs (HD) in 1983. The variance \$\textbackslash sigma\textasciicircum 2\_\textbraceleft\textbackslash rm tot\textbraceright (\textbackslash gamma)\$ in this correlation was recently calculated by Allen[11] for a single noise-free pulsar pair at angle \$\textbackslash gamma\$, which shows that after averaging over many pairs, the variance reduces to an intrinsic cosmic variance \$\textbackslash sigma\textasciicircum 2\_\textbraceleft\textbackslash rm cos\textbraceright (\textbackslash gamma)\$. Here, we extend this to an \$arbitrary\$ set of pulsars at specific sky locations, with pulsar pairs binned by \$\textbackslash gamma\$. We derive the linear combination of pulsar-pair correlations which is the optimal estimator of the HD correlation for each bin, illustrating our methods with plots of the expected range of variation away from the HD curve, for the sets of pulsars monitored by three active PTA collaborations. We compute the variance of and the covariance between these binned estimates, and show that these reduce to the cosmic variance and covariance \$s(\textbackslash gamma,\textbackslash gamma')\$ respectively, in the many-pulsar limit. The likely fluctuations away from the HD curve \$\textbackslash mu\_\textbraceleft\textbackslash rm u\textbraceright (\textbackslash gamma)\$ are strongly correlated/anticorrelated in the three angular regions where \$\textbackslash mu\_\textbraceleft\textbackslash rm u\textbraceright (\textbackslash gamma)\$ is successively positive, negative, and positive. We also construct the optimal estimator of the squared strain \$h\textasciicircum 2\$. When there are very many pulsar pairs, this determines \$h\textasciicircum 2\$ with arbitrary precision because PTAs probe an infinite set of GW modes. To assess observed deviations away from the HD curve, we characterize several \$\textbackslash chi\textasciicircum 2\$ goodness-of-fit statistics. We also show how pulsar noise and measurement noise can be included.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/LCYCJ9VK/Allen和Romano - 2023 - Hellings and Downs correlation of an arbitrary set of pulsars.pdf}
}

@article{Allen2023VarianceHellingsDownsCorrelation,
  title = {Variance of the {{Hellings-Downs Correlation}}},
  author = {Allen, Bruce},
  year = 2023,
  month = feb,
  journal = {Physical Review D},
  volume = {107},
  number = {4},
  eprint = {2205.05637},
  primaryclass = {gr-qc},
  pages = {043018},
  issn = {2470-0010, 2470-0029},
  doi = {10.1103/PhysRevD.107.043018},
  urldate = {2025-06-02},
  abstract = {Gravitational waves (GWs) create correlations in the arrival times of pulses from different pulsars. The expected correlation \$\textbackslash mu(\textbackslash gamma)\$ as a function of the angle \$\textbackslash gamma\$ between the directions to two pulsars was calculated by Hellings and Downs for an isotropic and unpolarized GW background, and several pulsar timing array (PTA) collaborations are working to observe these. We ask: given a set of noise-free observations, are they consistent with that expectation? To answer this, we calculate the expected variance \$\textbackslash sigma\textasciicircum 2(\textbackslash gamma)\$ in the correlation for a single GW point source, as pulsar pairs with fixed separation angle \$\textbackslash gamma\$ are swept around the sky. We then use this to derive simple analytic expressions for the variance produced by a set of discrete point sources uniformly scattered in space for two cases of interest: (1) point sources radiating GWs at the same frequency, generating confusion noise, and (2) point sources radiating GWs at distinct non-overlapping frequencies. By averaging over all pulsar sky positions at fixed separation angle \$\textbackslash gamma\$, we show how this variance may be cleanly split into cosmic variance and pulsar variance, also demonstrating that measurements of the variance can provide information about the nature of GW sources. In a series of technical appendices, we calculate the mean and variance of the Hellings-Downs correlation for an arbitrary (polarized) point source, quantify the impact of neglecting pulsar terms, and calculate the pulsar and cosmic variance for a Gaussian ensemble. The mean and variance of the Gaussian ensemble may also be obtained from the previous discrete-source confusion-noise model in the limit of a high density of weak sources.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/TNGMFYBQ/Allen - 2023 - Variance of the Hellings-Downs Correlation.pdf}
}

