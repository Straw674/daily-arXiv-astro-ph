}

@article{Janssens2017UltradiffuseUltracompactGalaxies,
  title = {Ultra-Diffuse and {{Ultra-compact Galaxies}} in the {{Frontier Fields Cluster Abell}} 2744},
  author = {Janssens, Steven and Abraham, Roberto and Brodie, Jean and Forbes, Duncan and Romanowsky, Aaron J. and van Dokkum, Pieter},
  year = 2017,
