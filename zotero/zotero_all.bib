@misc{
  title = {Unifying Cluster and Galaxy Cosmology Analyses Using the Galaxy-Halo Connection},
  author = {Cao, Shulei and Wu, Hao-Yi and Salcedo, Andr{\'e}s N. and Weinberg, David H. and Schaller, Matthieu and Schaye, Joop},
  year = 2026,
  month = jan,
  number = {arXiv:2601.16353},
  eprint = {2601.16353},
  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2601.16353},
  urldate = {2026-02-28},
  abstract = {Galaxies and galaxy clusters trace the same cosmic density field, but their statistics have been modeled separately in cosmological analyses. We present a unified, simulation-based framework to model them using the galaxy-halo connection. Our analysis includes cluster lensing, galaxy clustering, and galaxy-cluster cross-correlation. We validate our method on the FLAMINGO hydrodynamic simulation. Relative to the cluster-only approach, combining these probes improves the \${$\sigma\_$}8-\textohm\_m\$ figure of merit by a factor of 15. Our framework enables stringent tests of cosmological models and exploits small-scale information.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/MC5IGBHF/Cao 等 - 2026 - Unifying cluster and galaxy cosmology analyses using the galaxy-halo connection.pdf}
}

@misc{
  title = {Unified {{Latents}} ({{UL}}): {{How}} to Train Your Latents},
  shorttitle = {Unified {{Latents}} ({{UL}})},
  author = {Heek, Jonathan and Hoogeboom, Emiel and Mensink, Thomas and Salimans, Tim},
  year = 2026,
  month = feb,
  number = {arXiv:2602.17270},
  eprint = {2602.17270},
  primaryclass = {cs},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2602.17270},
  urldate = {2026-03-03},
  abstract = {We present Unified Latents (UL), a framework for learning latent representations that are jointly regularized by a diffusion prior and decoded by a diffusion model. By linking the encoder's output noise to the prior's minimum noise level, we obtain a simple training objective that provides a tight upper bound on the latent bitrate. On ImageNet-512, our approach achieves competitive FID of 1.4, with high reconstruction quality (PSNR) while requiring fewer training FLOPs than models trained on Stable Diffusion latents. On Kinetics-600, we set a new state-of-the-art FVD of 1.3.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/QNGZGN4C/Heek 等 - 2026 - Unified Latents (UL) How to train your latents.pdf}
}

