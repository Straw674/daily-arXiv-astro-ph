  author = {Butt, Minahil Adil and Haridasu, Sandeep and Diaferio, Antonaldo and Benetti, Francesco and Boumechta, Yacer and Baccigalupi, Carlo and Lapi, Andrea},
  year = 2025,
  month = apr,
  number = {arXiv:2504.16685},
  eprint = {2504.16685},
  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2504.16685},
  urldate = {2025-07-15},
  abstract = {We apply the caustic technique to samples of galaxy clusters stacked in redshift space to estimate the gravitational potential in the cluster's outer region and test modifications to the standard theory of gravity. We separate 122 galaxy clusters from the HeCS-SZ, HeCS-redMapper, and HeCS samples into four samples with increasing mass; we estimate four robust, highly constraining caustic profiles for these samples. The caustic masses of the four stacked clusters agree within \$ 10\textbackslash\%\$ with the corresponding median values of each cluster sample. By adopting the NFW density profile to model the gravitational potential, we recover the caustic profile \$\textbackslash mathcal\textbraceleft A\textbraceright (r)\$ up to radius \$r\_\textbraceleft\textbackslash rm p\textbraceright{} \textbackslash sim 4.0\textbackslash, \textbraceleft\textbackslash rm Mpc\textbraceright\$. This comparison is a first-order validation of the mass-concentration relation for galaxy clusters expected in the \$\textbackslash Lambda\$CDM model. We thus impose this correlation as a prior in our analysis. Based on our stacked clusters, we estimate the value of the filling factor, which enters the caustic technique, \$\textbackslash mathcal\textbraceleft F\textbraceright\_\textbraceleft\textbackslash beta\textbraceright{} = 0.59\textbackslash pm 0.05\$; we derive this value using real data alone and find it consistent with the value usually adopted in the literature. We then use the caustic profiles \$\textbackslash mathcal\textbraceleft A\textbraceright (r)\$ of the stacked clusters to constrain the chameleon gravity model. We find that the caustic profiles provide a stringent upper limit of \$\textbar f\_\textbraceleft\textbackslash rm R0\textbraceright\textbar{} \textbackslash lesssim 4 \textbackslash times 10\textasciicircum\textbraceleft -6\textbraceright\$ at \$95\textbackslash\%\$ C.L. limits in the \$f(\textbackslash mathcal\textbraceleft R\textbraceright )\$ scenario. The formalism developed here shall be further refined to test modifications to gravity in the extended outer weak gravitational regions of galaxy clusters.},
  archiveprefix = {arXiv},
  file = {/Users/xinq/Zotero/storage/MUPDLKEF/Butt 等 - 2025 - Outer regions of galaxy clusters as a new probe to test modifications to gravity.pdf}
}

