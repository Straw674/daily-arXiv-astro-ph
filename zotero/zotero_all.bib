  journal = {The Astrophysical Journal},
  volume = {885},
  pages = {131},
  issn = {0004-637X},
  doi = {10.3847/1538-4357/ab4a11},
  urldate = {2023-09-24},
  abstract = {We compile and analyze approximately 200 trigonometric parallaxes and proper motions of molecular masers associated with very young high-mass stars. Most of the measurements come from the BeSSeL Survey using the VLBA and the Japanese VERA project. These measurements strongly suggest that the Milky Way is a four-arm spiral, with some extra arm segments and spurs. Fitting log-periodic spirals to the locations of the masers, allowing for ``kinks'' in the spirals and using well-established arm tangencies in the fourth Galactic quadrant, allows us to significantly expand our view of the structure of the Milky Way. We present an updated model for its spiral structure and incorporate it into our previously published parallax-based distance-estimation program for sources associated with spiral arms. Modeling the three-dimensional space motions yields estimates of the distance to the Galactic center, \textbraceleft R\textbraceright 0=8.15+/- 0.15 \textbraceleft kpc\textbraceright, the circular rotation speed at the Sun's position, \textbraceleft\textbraceleft\textbraceleft\textbackslash Theta \textbraceright\textbraceright\textbraceright 0=236+/- 7 km s-1, and the nature of the rotation curve. Our data strongly constrain the full circular velocity of the Sun, \textbraceleft\textbraceleft\textbraceleft\textbackslash Theta \textbraceright\textbraceright\textbraceright 0+\textbraceleft V\textbraceright{$\odot$} =247+/- 4 km s-1, and its angular velocity, (\textbraceleft\textbraceleft\textbraceleft\textbackslash Theta \textbraceright\textbraceright\textbraceright 0+\textbraceleft V\textbraceright{$\odot$} )/\textbraceleft R\textbraceright 0=30.32+/- 0.27 km s-1 kpc-1. Transforming the measured space motions to a Galactocentric frame which rotates with the Galaxy, we find non-circular velocity components typically {$\lessequivlnt$}10 km s-1. However, near the Galactic bar and in a portion of the Perseus arm we find significantly larger non-circular motions. Young high-mass stars within 7 kpc of the Galactic center have a scale height of only 19 pc, and thus are well suited to define the Galactic plane. We find that the orientation of the plane is consistent with the IAU-defined plane to within \textpm 0.{$^\circ$}1, and that the Sun is offset toward the north Galactic pole by \textbraceleft Z\textbraceright{$\odot$} =5.5+/- 5.8 pc. Accounting for this offset places the central supermassive black hole, Sgr A*, in the midplane of the Galaxy. The measured motions perpendicular to the plane of the Galaxy limit precession of the plane to {$\lessequivlnt$}4 km s-1 at the radius of the Sun. Using our improved Galactic parameters, we predict the Hulse-Taylor binary pulsar to be at a distance of 6.54 \textpm{} 0.24 kpc, assuming its orbital decay from gravitational radiation follows general relativity.},
  annotation = {ADS Bibcode: 2019ApJ...885..131R\\
Read\_Status: New\\
Read\_Status\_Date: 2024-08-26T07:14:16.068Z},
  file = {/Users/xinq/Zotero/storage/Z79KHZY9/Reid et al_2019_Trigonometric Parallaxes of High-mass Star-forming Regions.pdf}
}

