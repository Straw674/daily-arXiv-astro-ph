  journal = {The Astrophysical Journal},
  volume = {687},
  pages = {12--21},
  issn = {0004-637X},
  doi = {10.1086/591512},
  urldate = {2025-09-04},
  abstract = {We investigate the origin of halo assembly bias, the dependence of halo clustering on assembly history. We relate halo assembly to peak properties measured in the Lagrangian space of the initial linear Gaussian random density field and show how these same Lagrangian properties determine large-scale bias. We focus on the two regimes where assembly bias has been observed to be significant: at masses very large and very small compared to the nonlinear mass scale. At high masses, we show that assembly bias is expected from the statistics of the peaks of Gaussian random fluctuations, and we show that the extent of assembly bias found in N-body simulations of rare halos is in excellent agreement with our theoretical prediction. At low masses, we argue that assembly bias largely arises from a subpopulation of low-mass halos whose mass accretion has ceased. Due to their arrested development, these halos naturally become unbiased, in contrast to their antibiased peers. We show that a simple toy model incorporating these effects can roughly reproduce the bias trends found in N-body simulations.},
  keywords = {/toread},
  annotation = {ADS Bibcode: 2008ApJ...687...12D},
  file = {/Users/xinq/Zotero/storage/D6NTI498/Dalal 等 - 2008 - Halo Assembly Bias in Hierarchical Structure Formation.pdf}
}

@misc{Dalal2025EstimatingNongaussianBias,
  title = {Estimating Non-Gaussian Bias Using Counts of Tracers},
  author = {Dalal, Neal and Percival, Will J.},
  year = 2025,
  month = mar,
  journal = {arXiv.org},
  urldate = {2025-04-16},
  abstract = {Local-type primordial non-gaussianity generates a distinctive term in the clustering of tracers of large-scale structure, behaving as \$k\textasciicircum\textbraceleft -2\textbraceright\$ at small wavenumbers \$k\$. In order to use this signal in a sample of galaxies to measure the amplitude of primordial non-gaussianity, \$f\_\textbraceleft NL\textbraceright\$, we need to independently determine the degenerate bias coefficient, \$b\_\textbackslash Phi\$, which quantifies the logarithmic response of the galaxy number density to a change in amplitude of the matter clustering. We study whether \$b\_\textbackslash Phi\$ may be estimated from the observed evolution of the number density of galaxies as a function of redshift. Using cosmological N-body simulations, we find that \$b\_\textbackslash Phi\$ may be estimated reasonably well for dark matter halos across the range of redshifts and halo masses used by large-scale structure surveys aimed at measuring \$f\_\textbraceleft NL\textbraceright\$. This includes non-gaussian secondary bias (or assembly bias) in halo concentration, which has previously been found to be quite large in amplitude. For an observed survey of galaxies, we additionally need to consider the selection function of the sample, which can introduce redshift dependence via cuts on apparent magnitude and colour. These effects of the selection function can be mitigated by further cutting the sample using k-corrected magnitudes and colours, to retain only those galaxies that would pass the targeting criteria for all redshifts within the interval considered.},
  howpublished = {https://arxiv.org/abs/2503.21024v1},
  langid = {english},
  file = {/Users/xinq/Zotero/storage/7X37W96J/Dalal和Percival - 2025 - Estimating non-gaussian bias using counts of tracers.pdf}
}

