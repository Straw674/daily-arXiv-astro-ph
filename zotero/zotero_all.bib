@misc{Taylor2025KinematicAge3I,
  title = {The {{Kinematic Age}} of {{3I}}/{{ATLAS}} and Its {{Implications}} for {{Early Planet Formation}}},
  author = {Taylor, Aster G. and Seligman, Darryl Z.},
  year = 2025,
  month = jul,
