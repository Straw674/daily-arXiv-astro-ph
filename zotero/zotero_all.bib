  file = {/Users/xinq/Zotero/storage/QRQ5VEI6/Motiwala 等 - 2025 - Are Gas-rich Ultra-diffuse Galaxies and Field Dwarfs Distinct.pdf}
}

@article{Mowla2017EvidenceAbsenceTidal,
  title = {Evidence of {{Absence}} of {{Tidal Features}} in the {{Outskirts}} of {{Ultra Diffuse Galaxies}} in the {{Coma Cluster}}},
