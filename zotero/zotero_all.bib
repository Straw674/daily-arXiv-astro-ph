}

@article{Amorisco2018GlobularClusterSystems,
  title = {The Globular Cluster Systems of 54 {{Coma}} Ultra-Diffuse Galaxies: Statistical Constraints from {{HST}} Data},
  shorttitle = {The Globular Cluster Systems of 54 {{Coma}} Ultra-Diffuse Galaxies},
  author = {Amorisco, N. C. and Monachesi, A. and Agnello, A. and White, S. D. M.},
