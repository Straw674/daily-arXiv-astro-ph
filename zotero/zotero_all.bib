@misc{Kanodia2025RevisitingCosmicDistance,
  title = {Revisiting {{Cosmic Distance Duality}} with {{Megamasers}} and {{DESI DR2}}: {{Model Independent Constraints}} on {{Early-Late Calibration}}},
