@article{Snyder2012ASSEMBLYREDSEQUENCE,
  title = {{{ASSEMBLY OF THE RED SEQUENCE IN INFRARED-SELECTED GALAXY CLUSTERS FROM THE IRAC SHALLOW CLUSTER SURVEY}}},
  author = {Snyder, Gregory F. and Brodwin, Mark and Mancone, Conor M. and Zeimann, Gregory R. and Stanford, S. A. and Gonzalez, Anthony H. and Stern, Daniel and Eisenhardt, Peter R. M. and Brown, Michael J. I. and Dey, Arjun and Jannuzi, Buell and Perlmutter, Saul},
  year = 2012,
